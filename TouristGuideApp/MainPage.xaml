<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TouristGuideApp.Services"
             x:Class="TouristGuideApp.MainPage"
             Title="{Binding [Tab_POI], Source={x:Static services:LocalizationResourceManager.Instance}}"
             BackgroundColor="#FDFBF7">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ── Hero Header ── -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#B84A39" Offset="0"/>
                    <GradientStop Color="#8B3E36" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <VerticalStackLayout Padding="20,18,20,22" Spacing="4">
                <Label Text="{Binding [AppTitle_Main], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="24" FontAttributes="Bold" TextColor="White"/>
                <Label Text="{Binding [AppDesc_Main], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#FFCCBC"/>
            </VerticalStackLayout>
        </Grid>

        <!-- ── Active POI Banner ── -->
        <Border Grid.Row="1" Margin="16,12,16,0" Padding="0" StrokeThickness="0"
                StrokeShape="RoundRectangle 16" x:Name="frameActivePOI"
                BackgroundColor="#2C4C3B">
            <Border.Shadow>
                <Shadow Brush="#2C4C3B" Offset="0,4" Radius="12" Opacity="0.2"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*" Padding="16,14" ColumnSpacing="14">
                <Border Grid.Column="0" BackgroundColor="#FFFFFF22" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="10">
                    <Label Text="📍" FontSize="22"/>
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="{Binding [POI_NearYou], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="10" FontAttributes="Bold"
                           TextColor="#A5D6A7" CharacterSpacing="1.5"/>
                    <Label x:Name="lblActivePOI"
                           Text="{Binding [POI_NoneNear], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontSize="15" FontAttributes="Bold"
                           TextColor="White" LineBreakMode="TailTruncation"/>
                    <Label x:Name="lblUserLocation"
                           Text="{Binding [POI_SearchingGPS], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontSize="11" TextColor="#FFFFFF99"
                           LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- ── POI List ── -->
        <CollectionView Grid.Row="2"
                        x:Name="listPOIs"
                        SelectionMode="Single"
                        SelectionChanged="OnPOISelectionChanged"
                        BackgroundColor="Transparent"
                        Margin="0,8,0,0">
            <CollectionView.Header>
                <Grid Padding="20,10,20,4">
                    <Label Text="{Binding [POI_List], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="11" FontAttributes="Bold"
                           TextColor="#B84A39" CharacterSpacing="1.5"/>
                </Grid>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="16,5" Padding="0" StrokeThickness="0"
                            StrokeShape="RoundRectangle 14" BackgroundColor="White">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPOITapped" CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="6,*" ColumnSpacing="0">
                            <!-- Colour accent bar -->
                            <BoxView Grid.Column="0" BackgroundColor="#B84A39"
                                     WidthRequest="6" CornerRadius="14,0,0,14"/>

                            <Grid Grid.Column="1" ColumnDefinitions="*,Auto"
                                  Padding="14,12" ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           FontAttributes="Bold" FontSize="15"
                                           TextColor="#2C4C3B"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding Description}"
                                           FontSize="12" TextColor="#888"
                                           MaxLines="1" LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                                <Border Grid.Column="1" BackgroundColor="#FBE9E7"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 20"
                                        Padding="10,5" VerticalOptions="Center">
                                    <Label Text="{Binding DistanceText}"
                                           FontSize="12" TextColor="#B84A39" FontAttributes="Bold"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <BoxView HeightRequest="12" Color="Transparent"/>
            </CollectionView.Footer>
        </CollectionView>

        <!-- ── Tracking Button ── -->
        <Border Grid.Row="3" Margin="16,0,16,20" StrokeThickness="0"
                StrokeShape="RoundRectangle 28" BackgroundColor="#B84A39">
            <Border.Shadow>
                <Shadow Brush="#B84A39" Offset="0,4" Radius="12" Opacity="0.35"/>
            </Border.Shadow>
            <Button x:Name="btnToggleTracking"
                    Text="{Binding [POI_StartTracking], Source={x:Static services:LocalizationResourceManager.Instance}}"
                    Clicked="OnToggleTrackingClicked"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="15"
                    HeightRequest="52"/>
        </Border>

    </Grid>

</ContentPage>
