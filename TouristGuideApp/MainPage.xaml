<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TouristGuideApp.MainPage"
             Title="Tourist GPS Guide">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            
            <Label Text="TOURIST GPS GUIDE"
                   FontSize="28"
                   HorizontalOptions="Center"
                   FontAttributes="Bold"
                   TextColor="#512BD4" />

            <!-- User Location Info -->
            <Frame CornerRadius="10" HasShadow="True" BorderColor="#512BD4">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Vị trí của bạn hiện tại:" FontAttributes="Bold" FontSize="16" />
                    <Label x:Name="lblUserLocation"
                           Text="Đang tìm vị trí GPS..."
                           FontSize="18"
                           TextColor="DarkSlateGray" />
                </VerticalStackLayout>
            </Frame>

            <!-- Active POI / Notification Area -->
            <Label Text="ĐIỂM ĐẾN ĐANG HOẠT ĐỘNG" FontAttributes="Bold" Margin="0,10,0,0"/>
            <Frame x:Name="frameActivePOI"
                   CornerRadius="10"
                   HasShadow="True"
                   BackgroundColor="LightGray"
                   HeightRequest="100">
                <VerticalStackLayout VerticalOptions="Center">
                    <Label x:Name="lblActivePOI"
                           Text="Không có điểm nào gần đây"
                           FontSize="20"
                           HorizontalOptions="Center"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- POI List -->
            <Label Text="DANH SÁCH CÁC ĐIỂM THAM QUAN" FontAttributes="Bold" Margin="0,10,0,0" />
            <CollectionView x:Name="listPOIs"
                            HeightRequest="300"
                            SelectionMode="Single"
                            SelectionChanged="OnPOISelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,5">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup Name="CommonStates">
                                    <VisualState Name="Normal" />
                                    <VisualState Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="#E6E0F8" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Frame Padding="15" CornerRadius="5" HasShadow="False" BorderColor="LightGray">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPOITapped" CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <HorizontalStackLayout Spacing="15">
                                    <BoxView Color="#512BD4" WidthRequest="5" HeightRequest="40" VerticalOptions="Center"/>
                                    <VerticalStackLayout VerticalOptions="Center">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" InputTransparent="True" />
                                        <Label Text="{Binding Description}" FontSize="12" MaxLines="1" LineBreakMode="TailTruncation" InputTransparent="True" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Frame>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button x:Name="btnToggleTracking"
                    Text="Bắt đầu theo dõi"
                    Clicked="OnToggleTrackingClicked"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="25"
                    HeightRequest="50" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
