<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TouristGuideApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TouristGuideApp"
    xmlns:views="clr-namespace:TouristGuideApp.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="#FFFFFF"
    Shell.TabBarForegroundColor="#B84A39"
    Shell.TabBarTitleColor="#B84A39"
    Shell.TabBarUnselectedColor="#999999"
    Shell.NavBarHasShadow="True"
    Shell.BackgroundColor="#B84A39"
    Shell.TitleColor="White"
    Shell.ForegroundColor="White">

    <TabBar>
        <Tab Title="Địa điểm" Icon="tab_poi.png">
            <ShellContent x:Name="listContent" />
        </Tab>
        <Tab Title="Bản đồ" Icon="tab_map.png">
            <ShellContent x:Name="mapContent" />
        </Tab>
        <Tab Title="Lộ trình" Icon="tab_tour.png">
            <ShellContent x:Name="toursContent" />
        </Tab>
        <Tab Title="Quét QR" Icon="tab_qr.png">
            <ShellContent x:Name="qrScanContent" />
        </Tab>
        <Tab Title="Cài đặt" Icon="tab_settings.png">
            <ShellContent x:Name="settingsContent" />
        </Tab>
    </TabBar>

</Shell>
