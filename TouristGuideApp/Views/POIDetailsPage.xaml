<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TouristGuideApp.Models"
             x:Class="TouristGuideApp.Views.POIDetailsPage"
             xmlns:views="clr-namespace:TouristGuideApp.Views"
             xmlns:services="clr-namespace:TouristGuideApp.Services"
             x:DataType="views:POIDetailsPage"
             Title="{Binding [POI_DetailTitle], Source={x:Static services:LocalizationResourceManager.Instance}}"
             BackgroundColor="#FDFBF7">

    <Grid BackgroundColor="#FDFBF7">
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- Hero Image Area -->
                <Grid HeightRequest="350">
                    <Image x:Name="imgLocation"
                           Aspect="AspectFill" />
                </Grid>

                <!-- Content Area -->
                <VerticalStackLayout Padding="24,10,24,30" Spacing="20">
                    
                    <!-- Title Section -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding POIItem.Category}" 
                               TextColor="#B84A39" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextTransform="Uppercase"/>
                        <Label Text="{Binding POIItem.Name}" 
                               TextColor="#2C4C3B" 
                               FontSize="28" 
                               FontAttributes="Bold"/>
                        <Label TextColor="#666666" FontSize="14">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0} {1}">
                                    <Binding Path="[POI_Distance_Prefix]" Source="{x:Static services:LocalizationResourceManager.Instance}" />
                                    <Binding Path="POIItem.DistanceText" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </VerticalStackLayout>

                    <!-- Listen Button -->
                    <Button Text="{Binding [POI_Listen], Source={x:Static services:LocalizationResourceManager.Instance}}"
                            Clicked="OnListenClicked"
                            BackgroundColor="#B84A39"
                            TextColor="White"
                            HeightRequest="70"
                            CornerRadius="35"
                            FontAttributes="Bold"/>

                    <!-- Description -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding [POI_Intro], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="18" FontAttributes="Bold" TextColor="#2C4C3B"/>
                        <WebView x:Name="wvDescription" 
                                 HeightRequest="500"
                                 Navigated="OnDescriptionWebViewNavigated"/>
                    </VerticalStackLayout>

                    <!-- Rating -->
                    <VerticalStackLayout Spacing="10" Margin="0,10,0,0">
                        <Label Text="Đánh giá" FontSize="18" FontAttributes="Bold" TextColor="#2C4C3B"/>
                        <HorizontalStackLayout Spacing="5">
                            <Button Text="⭐ 1" Clicked="OnStarClicked" CommandParameter="1" WidthRequest="60"/>
                            <Button Text="⭐ 2" Clicked="OnStarClicked" CommandParameter="2" WidthRequest="60"/>
                            <Button Text="⭐ 3" Clicked="OnStarClicked" CommandParameter="3" WidthRequest="60"/>
                            <Button Text="⭐ 4" Clicked="OnStarClicked" CommandParameter="4" WidthRequest="60"/>
                            <Button Text="⭐ 5" Clicked="OnStarClicked" CommandParameter="5" WidthRequest="60"/>
                        </HorizontalStackLayout>
                        <Label x:Name="lblRatingStatus" Text="Bạn thấy sao về quán này?" FontSize="12" TextColor="#888888"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
