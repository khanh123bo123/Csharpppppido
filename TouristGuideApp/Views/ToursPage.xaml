<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TouristGuideApp.Services"
             x:Class="TouristGuideApp.Views.ToursPage"
             Title="{Binding [Tab_Tours], Source={x:Static services:LocalizationResourceManager.Instance}}"
             BackgroundColor="#FDFBF7">

    <Grid RowDefinitions="Auto,*">

        <!-- Hero Header -->
        <Grid Grid.Row="0" BackgroundColor="#B84A39">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#B84A39" Offset="0"/>
                    <GradientStop Color="#8B3E36" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <VerticalStackLayout Padding="20,20,20,24" Spacing="4">
                <Label Text="{Binding [Tour_ViewTitle], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="26" FontAttributes="Bold" TextColor="White"/>
                <Label Text="{Binding [Tour_ViewDesc], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#FFCCBC"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Tour List -->
        <RefreshView Grid.Row="1" x:Name="RefreshTours" IsRefreshing="{Binding IsBusy}"
                     RefreshColor="#B84A39">
            <CollectionView x:Name="ToursList" SelectionMode="None"
                            BackgroundColor="#FDFBF7"
                            EmptyView="Chưa có lộ trình nào.">
                <CollectionView.Header>
                    <BoxView HeightRequest="8" Color="Transparent"/>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="16,6" Padding="0" StrokeThickness="0" StrokeShape="RoundRectangle 16"
                                BackgroundColor="White">
                            <Border.Shadow>
                                <Shadow Brush="#2C4C3B" Offset="0,3" Radius="12" Opacity="0.07"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTourTapped" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid RowDefinitions="Auto,Auto,Auto" Padding="18,16">

                                <!-- Tour Name + Distance -->
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontSize="17" FontAttributes="Bold"
                                           TextColor="#2C4C3B" LineBreakMode="TailTruncation"/>
                                    <Border Grid.Column="1"
                                            BackgroundColor="#FBE9E7"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 20"
                                            Padding="10,5"
                                            VerticalOptions="Center">
                                        <Label Text="{Binding EstimatedDistanceKm, StringFormat='📍 {0} km'}"
                                               FontSize="12" TextColor="#B84A39" FontAttributes="Bold"/>
                                    </Border>
                                </Grid>

                                <!-- Description -->
                                <Label Grid.Row="1"
                                       Text="{Binding Description}"
                                       FontSize="13" TextColor="#666"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2"
                                       Margin="0,8,0,12"/>

                                <!-- Footer: duration + CTA -->
                                <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                    <HorizontalStackLayout Grid.Column="0" Spacing="16" VerticalOptions="Center">
                                        <HorizontalStackLayout Spacing="5">
                                            <Label Text="⏱" FontSize="13"/>
                                            <Label Text="{Binding EstimatedDurationMinutes, StringFormat='{0} phút'}"
                                                   FontSize="13" TextColor="#888"/>
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>
                                    <Border Grid.Column="1"
                                            BackgroundColor="#B84A39"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 20"
                                            Padding="14,7">
                                        <Label Text="{Binding [Tour_ViewBtn], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13"
                                               TextColor="White" FontAttributes="Bold"/>
                                    </Border>
                                </Grid>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <BoxView HeightRequest="16" Color="Transparent"/>
                </CollectionView.Footer>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
