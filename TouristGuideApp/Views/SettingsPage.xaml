<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TouristGuideApp.Services"
             x:Class="TouristGuideApp.Views.SettingsPage"
             Title="{Binding [Tab_Settings], Source={x:Static services:LocalizationResourceManager.Instance}}"
             BackgroundColor="#FDFBF7">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#B84A39" Offset="0"/>
                        <GradientStop Color="#8B3E36" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <VerticalStackLayout Padding="20,20,20,28" Spacing="4">
                    <Label Text="{Binding [Settings_Title1], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="26" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="{Binding [Settings_Desc1], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#FFCCBC"/>
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Padding="16,20" Spacing="12">

                <!-- Section: Chung -->
                <Label Text="{Binding [Settings_GenTitle], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="11" FontAttributes="Bold"
                       TextColor="#B84A39" Margin="4,0,0,4"
                       CharacterSpacing="1.5"/>

                <!-- Location update setting -->
                <Border Padding="18,14" StrokeThickness="0"
                        StrokeShape="RoundRectangle 14" BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding [Settings_AutoLoc], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                   FontSize="15" FontAttributes="Bold" TextColor="#2C4C3B"/>
                            <Label Text="{Binding [Settings_AutoLocDesc], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                   FontSize="12" TextColor="#888"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="True" IsEnabled="False"
                                OnColor="#B84A39" ThumbColor="White"
                                VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Auto audio setting -->
                <Border Padding="18,14" StrokeThickness="0"
                        StrokeShape="RoundRectangle 14" BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding [Settings_AutoVoice], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                   FontSize="15" FontAttributes="Bold" TextColor="#2C4C3B"/>
                            <Label Text="{Binding [Settings_AutoVoiceDesc], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                   FontSize="12" TextColor="#888"/>
                        </VerticalStackLayout>
                        <Switch x:Name="swAutoAudio" Grid.Column="1" IsToggled="True"
                                OnColor="#B84A39" ThumbColor="White"
                                VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Language pack setting -->
                <Border Padding="18,14" StrokeThickness="0"
                        StrokeShape="RoundRectangle 14" BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding [Settings_Lang], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                   FontSize="15" FontAttributes="Bold" TextColor="#2C4C3B"/>
                            <Label Text="{Binding [Settings_LangDesc], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                   FontSize="12" TextColor="#888"/>
                        </VerticalStackLayout>
                        <Picker Grid.Column="1" x:Name="pickerLanguage"
                                Title="Chọn" WidthRequest="120" TextColor="#B84A39" HorizontalOptions="End"
                                SelectedIndexChanged="OnLanguageSelectedIndexChanged" />
                    </Grid>
                </Border>

                <!-- Section: Dữ liệu -->
                <Label Text="{Binding [Settings_DataTitle], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="11" FontAttributes="Bold"
                       TextColor="#B84A39" Margin="4,8,0,4"
                       CharacterSpacing="1.5"/>

                <!-- Clear history button -->
                <Border Padding="18,14" StrokeThickness="0"
                        StrokeShape="RoundRectangle 14" BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding [Settings_ClearHist], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                   FontSize="15" FontAttributes="Bold" TextColor="#2C4C3B"/>
                            <Label Text="{Binding [Settings_ClearHistDesc], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                   FontSize="12" TextColor="#888"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="1" BackgroundColor="#FBE9E7" StrokeThickness="0"
                                StrokeShape="RoundRectangle 20" Padding="14,8">
                            <Label Text="{Binding [Settings_ClearBtn], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13"
                                   TextColor="#B84A39" FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnClearHistoryClicked"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>
                    </Grid>
                </Border>

                <!-- Account Section -->
                <Label Text="TÀI KHOẢN" FontSize="11" FontAttributes="Bold" TextColor="#B84A39" Margin="4,8,0,0"/>
                <Border StrokeThickness="0" BackgroundColor="White" Padding="15" StrokeShape="RoundRectangle 14">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="UserEmailLabel" Text="Bạn đang đăng nhập với: ..." FontSize="14" TextColor="#666"/>
                        <Button Text="ĐĂNG XUẤT" Clicked="OnLogoutClicked" 
                                BackgroundColor="#B84A39" TextColor="White" 
                                CornerRadius="8" HeightRequest="45" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <!-- API Server Section -->
                <Label x:Name="ApiServerSectionLabel" Text="MÁY CHỦ API" FontSize="11" FontAttributes="Bold" TextColor="#B84A39" Margin="4,8,0,0"/>
                <Border x:Name="ApiServerSectionCard" StrokeThickness="0" BackgroundColor="White" Padding="15" StrokeShape="RoundRectangle 14">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <Entry x:Name="ApiBaseUrlEntry"
                               Placeholder="http://192.168.x.x:5214/"
                               Keyboard="Url"
                               TextColor="#333"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Text="LƯU URL API"
                                    Clicked="OnSaveApiBaseUrlClicked"
                                    BackgroundColor="#2C4C3B"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="42"/>
                            <Button Grid.Column="1" Text="KIỂM TRA KẾT NỐI"
                                    Clicked="OnTestApiConnectionClicked"
                                    BackgroundColor="#B84A39"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="42"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Section: Về ứng dụng -->
                <Label Text="{Binding [Settings_AppTitle], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="11" FontAttributes="Bold"
                       TextColor="#B84A39" Margin="4,8,0,4"
                       CharacterSpacing="1.5"/>

                <Border Padding="18,16" StrokeThickness="0"
                        StrokeShape="RoundRectangle 14" BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Border BackgroundColor="#FBE9E7" StrokeThickness="0"
                                StrokeShape="RoundRectangle 16" Padding="16,10"
                                HorizontalOptions="Center">
                            <Label Text="{Binding [Settings_Name], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="18"
                                   FontAttributes="Bold" TextColor="#B84A39"
                                   HorizontalOptions="Center"/>
                        </Border>
                        <Label Text="{Binding [Settings_D4], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13"
                               TextColor="#2C4C3B" HorizontalOptions="Center"
                               FontAttributes="Bold"/>
                        <Label Text="{Binding [Settings_Version], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12"
                               TextColor="#AAA" HorizontalOptions="Center"/>
                        
                        <Button Text="CẬP NHẬT ỨNG DỤNG"
                                Margin="0,10,0,0"
                                Clicked="OnUpdateAppClicked"
                                BackgroundColor="#2C4C3B"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="45"
                                FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
