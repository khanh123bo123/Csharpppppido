<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             xmlns:services="clr-namespace:TouristGuideApp.Services"
             x:Class="TouristGuideApp.Views.QRScanPage"
             Title="{Binding [Tab_QR], Source={x:Static services:LocalizationResourceManager.Instance}}"
             BackgroundColor="Black">

    <Grid>
        <!-- Camera View -->
        <zxing:CameraBarcodeReaderView
            x:Name="barcodeReader"
            CameraLocation="Rear"
            BarcodesDetected="CameraBarcodeReaderView_BarcodesDetected"
            HorizontalOptions="Fill"
            VerticalOptions="Fill"/>

        <!-- Top overlay: title -->
        <VerticalStackLayout VerticalOptions="Start" HorizontalOptions="Fill"
                             Padding="0,50,0,0">
            <Label Text="{Binding [QR_ScanTitle], Source={x:Static services:LocalizationResourceManager.Instance}}"
                   TextColor="White" FontSize="20" FontAttributes="Bold"
                   HorizontalOptions="Center">
                <Label.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.6"/>
                </Label.Shadow>
            </Label>
            <Label Text="{Binding [QR_ScanDesc], Source={x:Static services:LocalizationResourceManager.Instance}}"
                   TextColor="#FFCCBC" FontSize="13"
                   HorizontalOptions="Center"
                   Margin="20,6,20,0"
                   HorizontalTextAlignment="Center">
                <Label.Shadow>
                    <Shadow Brush="Black" Offset="0,1" Radius="3" Opacity="0.5"/>
                </Label.Shadow>
            </Label>
        </VerticalStackLayout>

        <!-- QR Frame guide in center -->
        <Grid HorizontalOptions="Center" VerticalOptions="Center"
              WidthRequest="220" HeightRequest="220">
            <!-- Corner borders using BoxViews -->
            <!-- Top-left -->
            <BoxView WidthRequest="36" HeightRequest="4" BackgroundColor="#B84A39"
                     HorizontalOptions="Start" VerticalOptions="Start"/>
            <BoxView WidthRequest="4" HeightRequest="36" BackgroundColor="#B84A39"
                     HorizontalOptions="Start" VerticalOptions="Start"/>
            <!-- Top-right -->
            <BoxView WidthRequest="36" HeightRequest="4" BackgroundColor="#B84A39"
                     HorizontalOptions="End" VerticalOptions="Start"/>
            <BoxView WidthRequest="4" HeightRequest="36" BackgroundColor="#B84A39"
                     HorizontalOptions="End" VerticalOptions="Start"/>
            <!-- Bottom-left -->
            <BoxView WidthRequest="36" HeightRequest="4" BackgroundColor="#B84A39"
                     HorizontalOptions="Start" VerticalOptions="End"/>
            <BoxView WidthRequest="4" HeightRequest="36" BackgroundColor="#B84A39"
                     HorizontalOptions="Start" VerticalOptions="End"/>
            <!-- Bottom-right -->
            <BoxView WidthRequest="36" HeightRequest="4" BackgroundColor="#B84A39"
                     HorizontalOptions="End" VerticalOptions="End"/>
            <BoxView WidthRequest="4" HeightRequest="36" BackgroundColor="#B84A39"
                     HorizontalOptions="End" VerticalOptions="End"/>
        </Grid>

        <Border VerticalOptions="End" HorizontalOptions="Fill"
                Margin="24,0,24,40" Padding="16,12"
                StrokeThickness="0" StrokeShape="RoundRectangle 16"
                BackgroundColor="#CC000000">
            <VerticalStackLayout Spacing="8">
                <Label Text="{Binding [QR_CameraHint], Source={x:Static services:LocalizationResourceManager.Instance}}"
                       TextColor="White" FontSize="13"
                       HorizontalOptions="Center"/>
                <Button Text="{Binding [QR_ManualInput], Source={x:Static services:LocalizationResourceManager.Instance}}"
                        BackgroundColor="#B84A39"
                        TextColor="White"
                        FontSize="14"
                        CornerRadius="10"
                        HeightRequest="40"
                        Clicked="OnManualInputClicked"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
