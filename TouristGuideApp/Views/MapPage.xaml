<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TouristGuideApp.Views.MapPage"
             Title="Bản đồ du lịch"
             BackgroundColor="#FDFBF7">

    <Grid RowDefinitions="*,Auto">

        <!-- Leaflet Map WebView -->
        <WebView x:Name="tourMapWebView" Grid.Row="0"/>

        <!-- Status Bar -->
        <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-2" Radius="8" Opacity="0.07"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto" Padding="16,12">
                <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                    <Label x:Name="lblMode"
                           Text="Chế độ: Online ☁️"
                           FontAttributes="Bold" FontSize="13"
                           TextColor="#B84A39"/>
                    <Label x:Name="lblStatus"
                           Text="Đang cập nhật vị trí..."
                           FontSize="12" TextColor="#888"/>
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        x:Name="btnCacheMap"
                        Text="💾 Lưu offline"
                        BackgroundColor="#2C4C3B"
                        TextColor="White"
                        CornerRadius="20"
                        FontSize="13"
                        HeightRequest="40"
                        Padding="14,0"
                        Clicked="OnCacheMapClicked"/>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
