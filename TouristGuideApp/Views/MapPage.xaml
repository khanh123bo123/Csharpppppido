<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TouristGuideApp.Views.MapPage"
             Title="Bản đồ du lịch">

    <Grid RowDefinitions="*,Auto">
        <!-- Leaflet map in WebView -->
        <WebView x:Name="tourMapWebView" Grid.Row="0" />

        <!-- Status bar -->
        <VerticalStackLayout Grid.Row="1" Padding="10" BackgroundColor="#F0F0F0" Spacing="5">
            <Label x:Name="lblMode" Text="Chế độ: Online ☁️" FontAttributes="Bold" TextColor="#FF6600" />
            <Label x:Name="lblStatus" Text="Đang cập nhật vị trí..." HorizontalOptions="Center" />
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Button x:Name="btnCacheMap" Text="Cache Bản đồ" Clicked="OnCacheMapClicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
