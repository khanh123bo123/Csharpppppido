{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🔥 Chạy API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build_api",
            "program": "${workspaceFolder}/TourGuideApi/bin/Debug/net10.0/TourGuideApi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/TourGuideApi",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": { "ASPNETCORE_ENVIRONMENT": "Development" }
        },
        {
            "name": "🌍 Chạy Web",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build_web",
            "program": "${workspaceFolder}/TouristGuideWeb/bin/Debug/net10.0/TouristGuideWeb.dll",
            "args": [],
            "cwd": "${workspaceFolder}/TouristGuideWeb",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": { "ASPNETCORE_ENVIRONMENT": "Development" }
        },
        {
            "name": "C#: TouristGuideApp [BabyCows 🐄]",
            "type": "maui",
            "request": "launch",
            "preLaunchTask": "build_app"
        }
    ],
    "compounds": [
        {
            "name": "🚀 CHẠY CÙNG LÚC API và WEB",
            "configurations": ["🔥 Chạy API", "🌍 Chạy Web"]
        }
    ]
}
