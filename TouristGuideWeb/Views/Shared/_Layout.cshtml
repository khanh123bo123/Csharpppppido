<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vĩnh Khánh Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.1.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TouristGuideWeb.styles.css" asp-append-version="true" />
    <style>
        html, body { height: 100%; margin: 0; font-family: 'Inter', sans-serif; background-color: #FDFBF7; color: #333; }
        h1, h2, h3, h4, h5, h6, .playfair { font-family: 'Playfair Display', serif; }
        .wrapper { display: flex; width: 100%; min-height: 100vh; }
        .sidebar { width: 250px; background: #fff; color: #333; border-right: 1px solid #EAE3D9; transition: all .3s; display: flex; flex-direction: column; }
        .sidebar .sidebar-header { padding: 24px 20px; text-align: center; font-size: 1.6rem; font-weight: 700; font-family: 'Playfair Display', serif; letter-spacing: .5px; border-bottom: 1px solid #EAE3D9; }
        .sidebar .sidebar-header a { color: #2C4C3B; text-decoration: none; display: flex; flex-direction: column; align-items: center; }
        .sidebar .sidebar-header .icon-logo { background: #B84A39; color: #fff; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 16px; margin-bottom: 10px; font-size: 1.2rem; }
        .sidebar ul.components { padding: 15px 0; flex-grow: 1; overflow-y: auto; }
        .sidebar ul li a { padding: 14px 20px; margin: 6px 16px; border-radius: 8px; font-size: 1.05rem; display: block; color: #555; font-weight: 500; text-decoration: none; transition: all .3s ease; }
        .sidebar ul li a i { margin-right: 14px; width: 24px; font-size: 1.15rem; text-align: center; }
        .sidebar ul li a:hover, .sidebar ul li.active > a { color: #fff; background: #B84A39; box-shadow: 0 4px 10px rgba(184,74,57,.25); }
        .sidebar-footer { padding: 20px; padding-bottom: 30px; border-top: 1px solid #EAE3D9; background: #fff; margin-top: auto; }
        .sidebar-footer .user-info { display: flex; justify-content: space-between; align-items: center; }
        .sidebar-footer .user-details { display: flex; flex-direction: column; }
        .sidebar-footer .user-role { font-size: 1.1rem; font-weight: 700; color: #2C4C3B; }
        .sidebar-footer .user-label { font-size: .8rem; text-transform: uppercase; letter-spacing: 1px; color: #888; }
        .btn-logout { color: #B84A39; background: rgba(184,74,57,.1); border: none; border-radius: 10px; width: 44px; height: 44px; font-size: 1.2rem; display: flex; align-items: center; justify-content: center; transition: all .3s ease; }
        .btn-logout:hover { background: #B84A39; color: #fff; }
        .main-content { flex: 1; display: flex; flex-direction: column; overflow-y: auto; }
        .content-body { padding: 25px; animation: fadeInSlideUp .6s ease-out forwards; }
        .card-premium { border: 1px solid #EAE3D9; border-radius: 16px; box-shadow: 0 4px 12px rgba(44,76,59,.03); transition: transform .3s cubic-bezier(.25,.8,.25,1), box-shadow .3s cubic-bezier(.25,.8,.25,1); background: #fff; margin-bottom: 25px; }
        .card-premium:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(44,76,59,.06); }
        .card-premium .card-header { background: transparent; border-bottom: 1px solid #EAE3D9; padding: 20px; font-weight: 600; }
        .card-premium .card-body { padding: 24px; }
        .stat-card { border-radius: 16px; padding: 24px; color: #fff; height: 100%; position: relative; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,.05); }
        .bg-orange { background: linear-gradient(135deg, #DD7A6B, #B84A39); }
        .bg-blue { background: linear-gradient(135deg, #7FA78E, #4A7C59); }
        .bg-green { background: linear-gradient(135deg, #E6CDAE, #C69A64); }
        .bg-pink { background: linear-gradient(135deg, #B16B61, #8B3E36); }
        .glass-card { background: rgba(255,255,255,.08); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,.15); border-radius: 24px; box-shadow: 0 20px 40px rgba(0,0,0,.2); color: #fff; transition: transform .4s ease, border-color .4s ease, box-shadow .4s ease; }
        .glass-card:hover { transform: translateY(-5px); border-color: rgba(255,255,255,.3); box-shadow: 0 25px 50px rgba(0,0,0,.3); }
        .glass-badge { padding: 6px 12px; background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2); border-radius: 20px; font-size: .85rem; color: rgba(255,255,255,.9); display: flex; align-items: center; gap: 6px; }
        .chevron-container { display: flex; justify-content: space-between; align-items: stretch; height: 140px; margin-bottom: 30px; }
        .chevron-wrapper { flex: 1; position: relative; filter: drop-shadow(0 10px 10px rgba(0,0,0,.1)); }
        .chevron-wrapper:nth-child(2), .chevron-wrapper:nth-child(3), .chevron-wrapper:nth-child(4) { margin-left: -25px; }
        .chevron-card { height: 100%; color: #fff; padding: 20px 20px 20px 45px; display: flex; flex-direction: column; justify-content: center; clip-path: polygon(0% 0%, 93% 0%, 100% 50%, 93% 100%, 0% 100%, 7% 50%); transition: transform .3s; }
        .chevron-card:hover { transform: translateY(-5px); }
        .chevron-wrapper:first-child .chevron-card { padding-left: 20px; clip-path: polygon(0% 0%, 93% 0%, 100% 50%, 93% 100%, 0% 100%); border-top-left-radius: 16px; border-bottom-left-radius: 16px; }
        .chevron-wrapper:last-child .chevron-card { clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%, 7% 50%); border-top-right-radius: 16px; border-bottom-right-radius: 16px; }
        .grad-orange { background: linear-gradient(135deg, #DD7A6B, #B84A39); }
        .grad-blue { background: linear-gradient(135deg, #7FA78E, #4A7C59); }
        .grad-green { background: linear-gradient(135deg, #E6CDAE, #C69A64); }
        .grad-purple { background: linear-gradient(135deg, #7C3AED, #4F46E5); }
        .action-card { position: relative; display: block; border-radius: 18px; padding: 20px; color: #fff; text-decoration: none; overflow: hidden; box-shadow: 0 8px 24px rgba(0,0,0,.12); min-height: 140px; }
        .action-card:hover { color: #fff; transform: translateY(-2px); }
        .action-title { font-size: 1.05rem; font-weight: 700; margin-top: 34px; }
        .action-desc { font-size: .9rem; opacity: .92; }
        .icon-top-right { position: absolute; right: 16px; top: 16px; font-size: 1.8rem; opacity: .25; }
        .text-dark-blue { color: #2C4C3B; }
        @@keyframes fadeInSlideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        @@media (max-width: 768px) {
            .sidebar { margin-left: -250px; }
            .sidebar.active { margin-left: 0; position: absolute; z-index: 1000; height: 100%; }
            .content-body { padding: 16px; }
            .chevron-container { height: auto; flex-direction: column; gap: 12px; }
            .chevron-wrapper { margin-left: 0 !important; }
        }
    </style>
</head>
<body>
    @if (ViewData["IsLandingPage"] as bool? == true)
    {
        @RenderBody()
    }
    else
    {
        <div class="wrapper">
            <!-- Sidebar -->
            <nav class="sidebar">
                <div class="sidebar-header">
                    <a asp-area="" asp-controller="Dashboard" asp-action="Index">
                        <div class="icon-logo">
                            <i class="fa-solid fa-camera-retro"></i>
                        </div>
                        Vĩnh Khánh
                        <span style="color: #B84A39; font-size: 0.9rem;">
                            @User.Identity?.Name
                        </span>
                    </a>
                </div>

                <ul class="list-unstyled components">
                    @if (User.IsInRole("Admin") || User.IsInRole("Owner"))
                    {
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                            <a asp-area="" asp-controller="Dashboard" asp-action="Index">
                                <i class="fa-solid fa-border-all"></i> Bảng điều khiển
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Locations" && ViewContext.RouteData.Values["Action"]?.ToString() != "IndexMap" ? "active" : "")">
                            <a asp-area="" asp-controller="Locations" asp-action="Index">
                                <i class="fa-solid fa-utensils"></i> Quản lý Quán
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Locations" && ViewContext.RouteData.Values["Action"]?.ToString() == "IndexMap" ? "active" : "")">
                            <a asp-area="" asp-controller="Locations" asp-action="IndexMap">
                                <i class="fa-solid fa-map"></i> Bản đồ
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Tours" ? "active" : "")">
                            <a asp-area="" asp-controller="Tours" asp-action="Index"><i class="fa-solid fa-route"></i> Lộ trình</a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Localizations" ? "active" : "")">
                            <a asp-area="" asp-controller="Localizations" asp-action="Index"><i class="fa-solid fa-language"></i> Dịch thuật</a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Audio" ? "active" : "")">
                            <a asp-area="" asp-controller="Audio" asp-action="Index"><i class="fa-solid fa-microphone"></i> Giọng đọc</a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Statistics" ? "active" : "")">
                            <a asp-area="" asp-controller="Statistics" asp-action="Index"><i class="fa-solid fa-chart-line"></i> Thống kê</a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "History" ? "active" : "")">
                            <a asp-area="" asp-controller="History" asp-action="Index"><i class="fa-solid fa-clock-rotate-left"></i> Lịch sử</a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")">
                            <a asp-area="" asp-controller="Users" asp-action="Index">
                                <i class="fa-solid fa-user"></i> Tài khoản
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Apk" ? "active" : "")">
                            <a asp-area="" asp-controller="Apk" asp-action="Index">
                                <i class="fa-solid fa-qrcode"></i> Tải APK
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Auth" && ViewContext.RouteData.Values["Action"]?.ToString() == "ChangePassword" ? "active" : "")">
                            <a asp-controller="Auth" asp-action="ChangePassword"><i class="fa-solid fa-lock"></i> Mật khẩu</a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Prd" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                            <a asp-controller="Prd" asp-action="Index"><i class="fa-solid fa-file-lines"></i> PRD v1.0</a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Prd" && ViewContext.RouteData.Values["Action"]?.ToString() == "UseCase" ? "active" : "")">
                            <a asp-controller="Prd" asp-action="UseCase"><i class="fa-solid fa-diagram-project"></i> Use Case</a>
                        </li>
                    }
                    else if (User.Identity?.IsAuthenticated == true)
                    {
                         <li>
                            <a href="#"><i class="fa-solid fa-circle-exclamation"></i> Chờ duyệt</a>
                        </li>
                    }
                </ul>
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="sidebar-footer">
                        <div class="user-info" style="position: relative; z-index: 10;">
                            <div class="user-details">
                                <span class="user-label" style="text-transform: uppercase;">
                                    TÀI KHOẢN
                                </span>
                                <span class="user-role">
                                    @User.Identity?.Name
                                </span>
                            </div>
                            <form method="post" action="/Auth/Logout" style="margin: 0;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-logout" title="Đăng xuất" style="cursor: pointer; position: relative; z-index: 10;">
                                    <i class="fa-solid fa-right-from-bracket"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </nav>

            <!-- Main Content -->
            <div class="main-content">
                <!-- Content Body -->
                <div class="content-body">
                    <main role="main">
                        @RenderBody()
                    </main>
                </div>
            </div>
        </div>
    }

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/2.1.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.1.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {
            $('#sidebarCollapse').on('click', function () {
                $('.sidebar').toggleClass('active');
            });
        });
    </script>

    @if (TempData["SuccessMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Thành công',
                text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(successMessage)),
                timer: 2200,
                showConfirmButton: false
            });
        </script>
    }
    @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Lỗi',
                text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(errorMessage))
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
