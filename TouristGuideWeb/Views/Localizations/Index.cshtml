@model IEnumerable<TouristGuideWeb.Models.Location>
@{
    ViewData["Title"] = "Quản lý Bản Dịch";
}

<div class="card-premium">
    <div class="card-header bg-white">
        <h5 class="fw-bold m-0 text-dark"><i class="fa-solid fa-language me-2 text-primary"></i> Quản lý Bản Dịch (Localizations)</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tên Quán Ăn (Location)</th>
                        <th>Danh mục</th>
                        <th>Người sở hữu</th>
                        <th class="text-end">Các bản dịch</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold text-primary">@item.Name</div>
                                <div class="text-muted small">@item.Address</div>
                            </td>
                            <td><span class="badge bg-secondary">@item.Category</span></td>
                            <td>@(string.IsNullOrEmpty(item.OwnerEmail) ? "Admin" : item.OwnerEmail)</td>
                            <td class="text-end">
                                <a asp-action="Manage" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">
                                    <i class="fa-solid fa-pen-nib me-1"></i> Quản lý dịch thuật
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">Bạn chưa tạo Địa Điểm/Quán Ăn nào để dịch.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
