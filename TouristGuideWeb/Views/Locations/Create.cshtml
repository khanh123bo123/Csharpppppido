@model TouristGuideWeb.Models.LocationCreateViewModel

@{
    ViewData["Title"] = "Create Location";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h1 class="h3 mb-0">Create Location</h1>
                        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                    </div>

                    <form asp-action="Create" method="post" class="row g-4">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="col-12">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="Enter location name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold">Mô tả ngắn</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Hiển thị trên app cho khách xem nhanh."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="AudioDescription" class="form-label fw-semibold">Mô tả audio (nguồn dịch thuật)</label>
                            <textarea asp-for="AudioDescription" class="form-control" rows="6" placeholder="Không hiển thị trên app. Chỉ dùng để dịch và tạo audio."></textarea>
                            <span asp-validation-for="AudioDescription" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Danh mục</label>
                            <div class="d-flex gap-2 mb-2">
                                <select id="categorySelect" class="form-select">
                                    <option value="">-- Chọn danh mục có sẵn --</option>
                                    @if (ViewBag.Categories != null)
                                    {
                                        foreach (var cat in (IEnumerable<string>)ViewBag.Categories)
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                    }
                                </select>
                                <button type="button" id="btnAddCategory" class="btn btn-outline-primary text-nowrap">Thêm mới</button>
                            </div>
                            <input type="text" id="newCategoryInput" class="form-control" style="display: none;" placeholder="Nhập danh mục mới..." />
                            <input asp-for="Category" type="hidden" id="categoryHiddenInput" />
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">Số điện thoại</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="0123456789" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>


                        <div class="col-12">
                            <label asp-for="ImageUrl" class="form-label fw-semibold">Link Hình ảnh (URL)</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>

                        <input asp-for="Latitude" id="latitudeInput" type="hidden" />
                        <input asp-for="Longitude" id="longitudeInput" type="hidden" />

                        <div class="col-12">
                            <label class="form-label fw-semibold">Select Coordinates On Map</label>
                            <div id="map" class="rounded border" style="height: 420px;"></div>
                            <div class="mt-3 small text-muted">
                                Current coordinates:
                                <span id="coordinatesLabel" class="fw-semibold text-dark"></span>
                            </div>
                            <span asp-validation-for="Latitude" class="text-danger d-block mt-1"></span>
                            <span asp-validation-for="Longitude" class="text-danger d-block"></span>
                        </div>

                        <div class="col-12 d-flex gap-2 pt-2">
                            <button type="submit" class="btn btn-primary px-4">Save</button>
                            <a asp-action="Index" class="btn btn-light border">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css" />
    <script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>
    <script>
        if (window.jQuery && $.validator) {
            $.validator.setDefaults({
                onkeyup: function (element) {
                    $(element).valid();
                },
                onfocusout: function (element) {
                    $(element).valid();
                }
            });

            const form = $('form');
            if (form.length) {
                form.removeData('validator');
                form.removeData('unobtrusiveValidation');
                $.validator.unobtrusive.parse(form);

                form.on('submit', function () {
                    if ($(this).valid()) {
                        const btn = $(this).find('button[type="submit"]');
                        btn.prop('disabled', true);
                        btn.html('<i class="fa-solid fa-spinner fa-spin me-2"></i>Saving...');
                    }
                });
            }
        }

        const defaultLat = 10.762622;
        const defaultLng = 106.660172;

        const latInput = document.getElementById('latitudeInput');
        const lngInput = document.getElementById('longitudeInput');

        const startLat = parseFloat(latInput.value || defaultLat);
        const startLng = parseFloat(lngInput.value || defaultLng);

        const coordsLabel = document.getElementById('coordinatesLabel');

        const map = L.map('map').setView([startLat, startLng], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        const marker = L.marker([startLat, startLng], { draggable: true }).addTo(map);

        // Add Geocoder focused on HCMC
        L.Control.geocoder({
            defaultMarkGeocode: false,
            placeholder: "Tìm kiếm địa chỉ tại TP.HCM...",
            geocoder: L.Control.Geocoder.nominatim({
                geocodingQueryParams: {
                    countrycodes: 'vn',
                    viewbox: '106.56,10.95,106.82,10.62',
                    bounded: 1 // strongly prefer results in HCMC
                }
            })
        })
        .on('markgeocode', function(e) {
            const bbox = e.geocode.bbox;
            const center = e.geocode.center;
            
            // Move marker and map
            marker.setLatLng(center);
            map.fitBounds(bbox);
            
            // Set inputs
            setInputs(center.lat, center.lng);
        })
        .addTo(map);

        function setInputs(lat, lng) {
            latInput.value = lat.toFixed(6);
            lngInput.value = lng.toFixed(6);
            coordsLabel.textContent = `${latInput.value}, ${lngInput.value}`;

            if (window.jQuery) {
                $(latInput).valid();
                $(lngInput).valid();
            }
        }

        setInputs(startLat, startLng);

        marker.on('dragend', function (e) {
            const pos = e.target.getLatLng();
            setInputs(pos.lat, pos.lng);
        });

        map.on('click', function (e) {
            marker.setLatLng(e.latlng);
            setInputs(e.latlng.lat, e.latlng.lng);
        });

        /* ========== CATEGORY PICKER ========== */
        const categorySelect = document.getElementById('categorySelect');
        const newCategoryInput = document.getElementById('newCategoryInput');
        const btnAddCategory = document.getElementById('btnAddCategory');
        const categoryHiddenInput = document.getElementById('categoryHiddenInput');

        function syncCategoryValue() {
            const selected = (categorySelect.value || '').trim();
            const custom = (newCategoryInput.value || '').trim();
            categoryHiddenInput.value = custom || selected;
        }

        categorySelect.addEventListener('change', function () {
            if ((categorySelect.value || '').trim()) {
                newCategoryInput.style.display = 'none';
                newCategoryInput.value = '';
            }
            syncCategoryValue();
        });

        btnAddCategory.addEventListener('click', function () {
            newCategoryInput.style.display = '';
            newCategoryInput.focus();
            categorySelect.value = '';
            syncCategoryValue();
        });

        newCategoryInput.addEventListener('input', syncCategoryValue);
        
        // Sync before submit
        document.querySelector('form').addEventListener('submit', function() {
            syncCategoryValue();
        });

        // Initial sync
        syncCategoryValue();
    </script>
}
