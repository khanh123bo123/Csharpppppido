@model TouristGuideWeb.Models.Location

@{
    ViewData["Title"] = "Location Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Location Details</h1>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@Model.Name</h5>
                <div class="mb-3">
                    @if (Model.RatingCount > 0)
                    {
                        <span class="text-warning">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fa-@(i <= Math.Round(Model.AverageRating) ? "solid" : "regular") fa-star"></i>
                            }
                        </span>
                        <span class="fw-bold ms-1">@Model.AverageRating</span>
                        <span class="text-muted ms-1 small">(@Model.RatingCount đánh giá)</span>
                    }
                    else
                    {
                        <span class="text-muted small">Chưa có đánh giá</span>
                    }
                </div>
                <p class="text-muted mb-2">@Model.Description</p>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Id</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4">Loại địa điểm</dt>
                    <dd class="col-sm-8">
                        @if (Model.Category?.StartsWith("minor:") == true)
                        {
                            var minorLabel = Model.Category switch
                            {
                                "minor:wc" => "🚻 Nhà vệ sinh (WC)",
                                "minor:ticket" => "🎫 Quầy bán vé",
                                "minor:parking" => "🅿️ Bãi giữ xe",
                                "minor:dock" => "⛵ Bến thuyền",
                                _ => "Tiện ích"
                            };
                            <span class="badge bg-warning text-dark fs-6">@minorLabel</span>
                            <span class="text-muted ms-1 small">Minor POI</span>
                        }
                        else if (!string.IsNullOrEmpty(Model.Category))
                        {
                            <span class="badge bg-primary fs-6"><i class="fa-solid fa-utensils me-1"></i>@Model.Category</span>
                            <span class="text-muted ms-1 small">Major POI</span>
                        }
                        else
                        {
                            <span class="text-muted">Chưa phân loại</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Phone</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "-" : Model.PhoneNumber)</dd>

                    <dt class="col-sm-4">Address</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Address) ? "-" : Model.Address)</dd>

                    <dt class="col-sm-4">Image URL</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                        {
                            <a href="@Model.ImageUrl" target="_blank">View Image</a>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Latitude</dt>
                    <dd class="col-sm-8">@Model.Latitude</dd>

                    <dt class="col-sm-4">Longitude</dt>
                    <dd class="col-sm-8">@Model.Longitude</dd>

                    <dt class="col-sm-4">QR Data</dt>
                    <dd class="col-sm-8">@Model.QrCodeData</dd>

                    <dt class="col-sm-4">Audio URL</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrWhiteSpace(Model.AudioUrl))
                        {
                            <a href="@Model.AudioUrl" target="_blank">@Model.AudioUrl</a>
                        }
                        else
                        {
                            <span class="text-muted">Not generated</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Created At</dt>
                    <dd class="col-sm-8">@Model.CreatedAt</dd>
                </dl>
            </div>
        </div>

        <div class="mt-3">
            <h2 class="h5">Map</h2>
            <div id="map" style="height: 360px; border: 1px solid #ddd;"></div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card text-center">
            <div class="card-body">
                <h2 class="h5">QR Code</h2>
                @if (!string.IsNullOrWhiteSpace(Model.QrCodeData))
                {
                    <img src="@Url.Action("GenerateQr", "Locations", new { qrData = Model.QrCodeData })"
                         alt="QR Code"
                         class="img-fluid border p-2 bg-white"
                         style="max-width: 280px;" />
                    <p class="text-muted mt-2 mb-3">Scan to get code: @Model.QrCodeData</p>
                    <a href="@Url.Action("GenerateQr", "Locations", new { qrData = Model.QrCodeData })" 
                       download="QRCode_@(Model.Id).png" 
                       class="btn btn-outline-primary btn-sm mt-2">
                        <i class="bi bi-download"></i> Tải hình ảnh về máy
                    </a>
                }
                else
                {
                    <p class="text-muted mb-0">QR data is not available.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const lat = @Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const lng = @Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);

        const map = L.map('map').setView([lat, lng], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        L.marker([lat, lng]).addTo(map)
            .bindPopup('@Model.Name')
            .openPopup();
    </script>
}
