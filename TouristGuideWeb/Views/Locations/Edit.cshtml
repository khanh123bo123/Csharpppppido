@model TouristGuideWeb.Models.LocationEditViewModel

@{
    ViewData["Title"] = "Edit Location";
}

<h1 class="h3 mb-3">Edit Location</h1>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label class="form-label fw-semibold">Loại địa điểm <span class="text-danger">*</span></label>
        <div class="d-flex gap-4 mb-2">
            <div class="form-check">
                <input class="form-check-input" type="radio" name="poiTypeRadio" id="poiTypeMajor" value="Major" onchange="togglePoiType()">
                <label class="form-check-label fw-semibold" for="poiTypeMajor">
                    <i class="fa-solid fa-utensils text-primary me-1"></i> Quán ăn (Major)
                </label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" name="poiTypeRadio" id="poiTypeMinor" value="Minor" onchange="togglePoiType()">
                <label class="form-check-label fw-semibold" for="poiTypeMinor">
                    <i class="fa-solid fa-signs-post text-warning me-1"></i> Tiện ích (Minor)
                </label>
            </div>
        </div>
    </div>

    <div class="col-md-6" id="majorCategoryGroup">
        <label class="form-label fw-semibold">Danh mục ẩm thực</label>
        <input type="text" id="majorCategoryInput" class="form-control" placeholder="VD: Phở, Bánh Mì, Hải Sản..." />
        <span asp-validation-for="Category" class="text-danger"></span>
    </div>

    <div class="col-md-6" id="minorCategoryGroup" style="display: none;">
        <label class="form-label fw-semibold">Loại tiện ích <span class="text-danger">*</span></label>
        <select id="minorCategorySelect" class="form-select">
            <option value="minor:wc">🚻 Nhà vệ sinh (WC)</option>
            <option value="minor:ticket">🎫 Quầy bán vé</option>
            <option value="minor:parking">🅿️ Bãi giữ xe</option>
            <option value="minor:dock">⛵ Bến thuyền</option>
        </select>
    </div>

    <input asp-for="Category" type="hidden" id="categoryHiddenInput" />

    <div class="col-md-6">
        <label asp-for="PhoneNumber" class="form-label">Số điện thoại</label>
        <input asp-for="PhoneNumber" class="form-control" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Address" class="form-label">Địa chỉ cụ thể</label>
        <input asp-for="Address" class="form-control" />
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="ImageUrl" class="form-label">Link Hình ảnh (URL)</label>
        <input asp-for="ImageUrl" class="form-control" />
        <span asp-validation-for="ImageUrl" class="text-danger"></span>
    </div>

    <input asp-for="Latitude" type="hidden" id="latitudeInput" />
    <input asp-for="Longitude" type="hidden" id="longitudeInput" />

    <div class="col-12">
        <label class="form-label">Adjust location on map</label>
        <div id="map" style="height: 400px; border: 1px solid #ddd;"></div>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css" />
    <script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>
    <script>
        if (window.jQuery && $.validator) {
            $.validator.setDefaults({
                onkeyup: function (element) {
                    $(element).valid();
                },
                onfocusout: function (element) {
                    $(element).valid();
                }
            });

            const form = $('form');
            if (form.length) {
                form.removeData('validator');
                form.removeData('unobtrusiveValidation');
                $.validator.unobtrusive.parse(form);

                form.on('submit', function () {
                    if ($(this).valid()) {
                        const btn = $(this).find('button[type="submit"]');
                        btn.prop('disabled', true);
                        btn.html('<i class="fa-solid fa-spinner fa-spin me-2"></i>Saving...');
                    }
                });
            }
        }

        const latInput = document.getElementById('latitudeInput');
        const lngInput = document.getElementById('longitudeInput');

        const startLat = parseFloat(latInput.value || '0');
        const startLng = parseFloat(lngInput.value || '0');

        const map = L.map('map').setView([startLat, startLng], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        const marker = L.marker([startLat, startLng], { draggable: true }).addTo(map);

        // Add Geocoder
        L.Control.geocoder({
            defaultMarkGeocode: false,
            placeholder: "Tìm kiếm địa điểm..."
        })
        .on('markgeocode', function(e) {
            const bbox = e.geocode.bbox;
            const center = e.geocode.center;
            
            // Move marker and map
            marker.setLatLng(center);
            map.fitBounds(bbox);
            
            // Set inputs
            setInputs(center.lat, center.lng);
        })
        .addTo(map);

        function setInputs(lat, lng) {
            latInput.value = lat.toFixed(6);
            lngInput.value = lng.toFixed(6);

            if (window.jQuery) {
                $(latInput).valid();
                $(lngInput).valid();
            }
        }

        marker.on('dragend', function (e) {
            const pos = e.target.getLatLng();
            setInputs(pos.lat, pos.lng);
        });

        map.on('click', function (e) {
            marker.setLatLng(e.latlng);
            setInputs(e.latlng.lat, e.latlng.lng);
        });

        // POI Type toggle logic
        function togglePoiType() {
            const isMajor = document.getElementById('poiTypeMajor').checked;
            document.getElementById('majorCategoryGroup').style.display = isMajor ? '' : 'none';
            document.getElementById('minorCategoryGroup').style.display = isMajor ? 'none' : '';
            syncCategory();
        }

        function syncCategory() {
            const isMajor = document.getElementById('poiTypeMajor').checked;
            const hidden = document.getElementById('categoryHiddenInput');
            if (isMajor) {
                hidden.value = document.getElementById('majorCategoryInput').value || '';
            } else {
                hidden.value = document.getElementById('minorCategorySelect').value;
            }
        }

        document.getElementById('majorCategoryInput').addEventListener('input', syncCategory);
        document.getElementById('minorCategorySelect').addEventListener('change', syncCategory);
        document.querySelector('form').addEventListener('submit', function() { syncCategory(); });

        // Pre-fill from existing Category value
        (function initPoiType() {
            const existing = document.getElementById('categoryHiddenInput').value || '';
            if (existing.startsWith('minor:')) {
                document.getElementById('poiTypeMinor').checked = true;
                document.getElementById('minorCategorySelect').value = existing;
            } else {
                document.getElementById('poiTypeMajor').checked = true;
                document.getElementById('majorCategoryInput').value = existing;
            }
            togglePoiType();
        })();
    </script>
}
