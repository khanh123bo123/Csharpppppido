@model IEnumerable<TouristGuideWeb.Models.Location>

@{
    ViewData["Title"] = "Locations";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Danh sach dia diem</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>Them moi
    </a>
</div>

<div class="table-responsive">
    <table id="locationsTable" class="table table-striped table-bordered align-middle">
        <thead>
            <tr>
                <th>Id</th>
                <th>Ten</th>
                <th>Toa do</th>
                <th>Hanh dong</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Latitude.ToString("0.######"), @item.Longitude.ToString("0.######")</td>
                <td class="text-nowrap">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                        <i class="fa-solid fa-pen-to-square"></i>
                    </a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white" title="Details">
                        <i class="fa-solid fa-circle-info"></i>
                    </a>
                    <button type="button"
                            class="btn btn-sm btn-danger btn-delete"
                            data-id="@item.Id"
                            data-name="@item.Name"
                            title="Delete">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<form id="deleteForm" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" id="deleteId" name="id" />
</form>

<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteConfirmModalLabel">Xac nhan xoa</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Ban co chac chan muon xoa dia diem <strong id="deleteLocationName"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huy</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fa-solid fa-trash me-1"></i>Xoa
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            new DataTable('#locationsTable', {
                language: {
                    search: 'Tim kiem:',
                    lengthMenu: 'Hien thi _MENU_ dong',
                    info: 'Hien thi _START_ den _END_ cua _TOTAL_ dong',
                    paginate: {
                        first: 'Dau',
                        last: 'Cuoi',
                        next: 'Sau',
                        previous: 'Truoc'
                    },
                    emptyTable: 'Khong co du lieu'
                }
            });

            const deleteModalElement = document.getElementById('deleteConfirmModal');
            const deleteModal = new bootstrap.Modal(deleteModalElement);
            let selectedId = null;

            $('.btn-delete').on('click', function () {
                selectedId = $(this).data('id');
                const name = $(this).data('name');
                $('#deleteLocationName').text(name);
                deleteModal.show();
            });

            $('#confirmDeleteBtn').on('click', function () {
                if (!selectedId) {
                    return;
                }

                $('#deleteId').val(selectedId);
                $('#deleteForm').submit();
            });
        });
    </script>
}
