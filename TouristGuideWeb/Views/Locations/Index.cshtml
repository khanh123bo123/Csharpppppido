@model IEnumerable<TouristGuideWeb.Models.Location>

@{
    ViewData["Title"] = "Locations";
}

<div class="row mb-3">
    <div class="col">
        <h1 class="h3 mb-0">Danh sách địa điểm</h1>
    </div>
    <div class="col-auto">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Tìm kiếm địa điểm..." style="width: 200px;" />
            
            <select name="category" class="form-select" style="width: 180px;" onchange="this.form.submit()">
                <option value="">Tất cả danh mục</option>
                @{
                    var currentCategory = ViewData["CurrentCategory"] as string;
                    var categories = ViewBag.Categories as List<string> ?? new List<string>();
                    foreach (var cat in categories)
                    {
                        if (cat == currentCategory)
                        {
                            <option value="@cat" selected>@cat</option>
                        }
                        else
                        {
                            <option value="@cat">@cat</option>
                        }
                    }
                }
            </select>

            <button type="submit" class="btn btn-secondary">
                <i class="fa-solid fa-magnifying-glass me-1"></i>Tìm
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Xoá lọc</a>
        </form>
    </div>
    <div class="col-auto">
        <div class="d-flex gap-2">
            <button type="submit" form="exportPdfForm" class="btn btn-outline-danger" id="exportSelectedBtn" disabled>
                <i class="fa-solid fa-file-pdf me-1"></i>Xuất PDF đã chọn
            </button>
            <a asp-action="ExportQrPdf" class="btn btn-danger">
                <i class="fa-solid fa-file-export me-1"></i>Xuất PDF tất cả
            </a>
            
            <form asp-action="ReprocessAll" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn kích hoạt dịch lại toàn bộ các địa điểm không? Quá trình này sẽ tốn tài nguyên máy chủ.');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-warning">
                    <i class="fa-solid fa-language me-1"></i> Dịch lại toàn bộ
                </button>
            </form>

            <a asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-plus me-1"></i>Thêm mới
            </a>
        </div>
    </div>
</div>

<form id="exportPdfForm" asp-action="ExportQrPdf" method="get"></form>

<div class="table-responsive">
    <table id="locationsTable" class="table table-striped table-bordered align-middle">
        <thead>
            <tr>
                <th class="text-center" style="width: 48px;">
                    <input type="checkbox" id="selectAllRows" class="form-check-input" title="Chon tat ca" />
                </th>
                <th>Id</th>
                <th>Tên</th>
                <th>Đánh giá</th>
                <th>Loại</th>
                <th>Tọa độ</th>
                <th class="text-center">Mã QR</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="text-center">
                    <input type="checkbox"
                           class="form-check-input row-select"
                           name="ids"
                           value="@item.Id"
                           form="exportPdfForm" />
                </td>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>
                    @if (item.RatingCount > 0)
                    {
                        <div class="text-warning small">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fa-@(i <= Math.Round(item.AverageRating) ? "solid" : "regular") fa-star"></i>
                            }
                            <span class="text-muted ms-1">(@item.AverageRating)</span>
                        </div>
                    }
                    else
                    {
                        <span class="text-muted small">Chưa có</span>
                    }
                </td>
                <td>
                    @if (item.Category?.StartsWith("minor:") == true)
                    {
                        var minorLabel = item.Category switch
                        {
                            "minor:wc" => "🚻 WC",
                            "minor:ticket" => "🎫 Bán vé",
                            "minor:parking" => "🅿️ Gửi xe",
                            "minor:dock" => "⛵ Bến thuyền",
                            _ => "Tiện ích"
                        };
                        <span class="badge bg-warning text-dark">@minorLabel</span>
                    }
                    else if (!string.IsNullOrEmpty(item.Category))
                    {
                        <span class="badge bg-primary">@item.Category</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Chưa phân loại</span>
                    }
                </td>
                <td>@item.Latitude.ToString("0.######"), @item.Longitude.ToString("0.######")</td>
                <td class="text-center">
                    @if (!string.IsNullOrEmpty(item.QrCodeData))
                    {
                        <div class="d-flex flex-column align-items-center">
                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=@(Uri.EscapeDataString(item.QrCodeData))" 
                                 alt="QR Code" 
                                 class="border rounded shadow-sm"
                                 style="width: 64px; height: 64px; cursor: pointer; background: white;"
                                 onclick="window.open(this.src)" />
                            <span class="text-muted mt-1" style="font-size: 0.7rem;">@item.QrCodeData</span>
                        </div>
                    }
                    else
                    {
                        <span class="text-muted small">N/A</span>
                    }
                </td>
                <td class="text-nowrap">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                        <i class="fa-solid fa-pen-to-square"></i>
                    </a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white" title="Details">
                        <i class="fa-solid fa-circle-info"></i>
                    </a>
                    <button type="button"
                            class="btn btn-sm btn-danger btn-delete"
                            data-id="@item.Id"
                            data-name="@item.Name"
                            title="Delete">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<form id="deleteForm" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" id="deleteId" name="id" />
</form>

<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteConfirmModalLabel">Xác nhận xoá</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Bạn có chắc chắn muốn xoá địa điểm <strong id="deleteLocationName"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fa-solid fa-trash me-1"></i>Xoá
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            const table = new DataTable('#locationsTable', {
                language: {
                    search: 'Tìm kiếm:',
                    lengthMenu: 'Hiển thị _MENU_ dòng',
                    info: 'Hiển thị _START_ đến _END_ của _TOTAL_ dòng',
                    paginate: {
                        first: 'Đầu',
                        last: 'Cuối',
                        next: 'Sau',
                        previous: 'Trước'
                    },
                    emptyTable: 'Không có dữ liệu'
                },
                columnDefs: [
                    { targets: [0, 4], orderable: false, searchable: false }
                ]
            });

            const deleteModalElement = document.getElementById('deleteConfirmModal');
            document.body.appendChild(deleteModalElement);
            const deleteModal = new bootstrap.Modal(deleteModalElement);
            let selectedId = null;

            function updateExportState() {
                const hasSelected = $('.row-select:checked').length > 0;
                $('#exportSelectedBtn').prop('disabled', !hasSelected);
            }

            $('#selectAllRows').on('change', function () {
                const checked = $(this).is(':checked');
                $('.row-select').prop('checked', checked);
                updateExportState();
            });

            $(document).on('change', '.row-select', function () {
                const total = $('.row-select').length;
                const selected = $('.row-select:checked').length;
                $('#selectAllRows').prop('checked', total > 0 && total === selected);
                updateExportState();
            });

            table.on('draw', function () {
                const total = $('.row-select').length;
                const selected = $('.row-select:checked').length;
                $('#selectAllRows').prop('checked', total > 0 && total === selected);
                updateExportState();
            });

            $(document).on('click', '.btn-delete', function () {
                selectedId = $(this).data('id');
                const name = $(this).data('name');
                $('#deleteLocationName').text(name);
                deleteModal.show();
            });

            $('#confirmDeleteBtn').on('click', function () {
                if (!selectedId) {
                    return;
                }

                $('#deleteId').val(selectedId);
                $('#deleteForm').submit();
            });
        });
    </script>
}
