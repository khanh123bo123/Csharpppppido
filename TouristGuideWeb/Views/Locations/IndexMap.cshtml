@model IEnumerable<TouristGuideWeb.Models.Location>

@{
    ViewData["Title"] = "Locations Map";
    var detailsUrlTemplate = Url.Action("Details", "Locations", new { id = "__id__" }) ?? "/Locations/Details/__id__";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Ban do dia diem</h1>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="fa-solid fa-table me-1"></i>Xem dang bang
        </a>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus me-1"></i>Them moi
        </a>
    </div>
</div>

<div id="locationsMap" class="border rounded shadow-sm" style="height: 560px;"></div>

@section Scripts {
    <script>
        (function () {
            const locations = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
            const detailsUrlTemplate = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(detailsUrlTemplate));

            const defaultLat = 10.7578; // Center closer to Vĩnh Khánh (Ốc Đào)
            const defaultLng = 106.6978;
            const map = L.map('locationsMap').setView([defaultLat, defaultLng], 14);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            // Re-invalidate size to fix potential issues with container height
            setTimeout(() => { map.invalidateSize(); }, 300);

            const bounds = [];

            function escapeHtml(value) {
                if (value === null || value === undefined) return '';
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/\"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            // Custom icons for Major vs Minor POIs - using more reliable CDN links
            const majorIcon = L.icon({
                iconUrl: 'https://cdn.jsdelivr.net/gh/pointhi/leaflet-color-markers@master/img/marker-icon-2x-blue.png',
                shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-shadow.png',
                iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34], shadowSize: [41, 41]
            });
            const minorIcon = L.icon({
                iconUrl: 'https://cdn.jsdelivr.net/gh/pointhi/leaflet-color-markers@master/img/marker-icon-2x-orange.png',
                shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-shadow.png',
                iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34], shadowSize: [41, 41]
            });

            const minorLabels = {
                'minor:wc': '🚻 WC',
                'minor:ticket': '🎫 Bán vé',
                'minor:parking': '🅿️ Gửi xe',
                'minor:dock': '⛵ Bến thuyền'
            };

            if (locations && locations.length > 0) {
                locations.forEach(function (location) {
                    // Try both cases just in case
                    let lat = location.latitude !== undefined ? location.latitude : location.Latitude;
                    let lng = location.longitude !== undefined ? location.longitude : location.Longitude;
                    const id = location.id !== undefined ? location.id : location.Id;
                    const name = location.name !== undefined ? location.name : location.Name;
                    const category = location.category !== undefined ? location.category : location.Category;

                    // Support string coordinates from inputs
                    if (typeof lat === 'string') lat = parseFloat(lat);
                    if (typeof lng === 'string') lng = parseFloat(lng);

                    if (isNaN(lat) || isNaN(lng) || lat === null || lng === null) {
                        return;
                    }

                    const cat = category || '';
                    const isMinor = cat.startsWith('minor:');
                    const icon = isMinor ? minorIcon : majorIcon;
                    
                    const marker = L.marker([lat, lng], { icon: icon }).addTo(map);
                    const detailsUrl = detailsUrlTemplate.replace('__id__', String(id));
                    
                    let categoryBadge = '';
                    if (isMinor) {
                        categoryBadge = `<span class="badge bg-warning text-dark">${escapeHtml(minorLabels[cat] || 'Tiện ích')}</span>`;
                    } else if (cat) {
                        categoryBadge = `<span class="badge bg-primary">${escapeHtml(cat)}</span>`;
                    }

                    const popupHtml = `
                        <div style="min-width: 180px;">
                            <div class="fw-semibold mb-1">${escapeHtml(name)}</div>
                            ${categoryBadge ? `<div class="mb-2">${categoryBadge}</div>` : ''}
                            <a class="btn btn-sm btn-primary" href="${detailsUrl}">Xem chi tiết</a>
                        </div>`;

                    marker.bindPopup(popupHtml);
                    bounds.push([lat, lng]);
                });
            }

            if (bounds.length > 0) {
                map.fitBounds(bounds, { padding: [30, 30] });
            }

            // Real-time Browser Geolocation for "My Location" on Web
            const userIcon = L.icon({
                iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-red.png',
                shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-shadow.png',
                iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34], shadowSize: [41, 41]
            });

            let webUserMarker = null;

            if (navigator.geolocation) {
                navigator.geolocation.watchPosition(function(position) {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;

                    if (!webUserMarker) {
                        webUserMarker = L.marker([lat, lng], { icon: userIcon }).addTo(map)
                            .bindPopup('<b>V\u1ecb tr\u00ed c\u1ee7a b\u1ea1n</b>').openPopup();
                        
                        // If no other POIs, center on user
                        if (bounds.length === 0) {
                            map.setView([lat, lng], 16);
                        }
                    } else {
                        webUserMarker.setLatLng([lat, lng]);
                    }
                }, function(err) {
                    console.warn('Geolocation error:', err);
                }, {
                    enableHighAccuracy: true,
                    timeout: 5000,
                    maximumAge: 0
                });
            }
        })();
    </script>
}
