@model IEnumerable<TouristGuideWeb.Models.LocalizationDto>
@{
    ViewData["Title"] = "Quản lý Giọng Đọc (TTS)";

    double? speechRate = null;
    try
    {
        speechRate = (double?)ViewBag.EdgeTtsSpeechRate;
    }
    catch
    {
        speechRate = null;
    }
}

<div class="card-premium">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="fw-bold m-0"><i class="fa-solid fa-microphone-lines text-danger me-2"></i> Trình quản lý Giọng Đọc AI (TTS)</h5>

        @if (User.IsInRole("Admin"))
        {
            <form asp-action="UpdateSpeechRate" method="post" class="d-flex align-items-center gap-2">
                <span class="small text-muted">Tốc độ đọc</span>
                <input type="number"
                       name="speechRate"
                       step="0.05"
                       min="0.1"
                       max="4.0"
                       value="@(speechRate ?? 1.0)"
                       class="form-control form-control-sm"
                       style="width: 90px;" />
                <button type="submit" class="btn btn-sm btn-outline-primary">Lưu</button>
            </form>
        }
    </div>
    <div class="px-3 py-2 bg-white border-top border-bottom">
        <div class="small text-muted">
            1.0 = bình thường. Thay đổi áp dụng cho audio tạo mới; audio cũ cần bấm “đọc lại”.
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tên Quán (Gốc)</th>
                        <th>Ngôn ngữ</th>
                        <th>Bản Mệnh lệnh (Kịch bản AI)</th>
                        <th>Trạng thái Audio</th>
                        <th class="text-end">Nghe / Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@item.Location?.Name</td>
                            <td><span class="badge bg-secondary">@item.LanguageCode</span></td>
                            <td class="text-muted small">
                                @(item.LocalizedDescription?.Length > 40 ? item.LocalizedDescription.Substring(0, 40) + "..." : item.LocalizedDescription)
                            </td>
                            <td>
                                @if (item.AudioGenerationStatus == "generated" || item.AudioGenerationStatus == "cached")
                                {
                                    <span class="badge bg-success px-2 py-1"><i class="fa-solid fa-check me-1"></i> Hoàn tất</span>
                                }
                                else if (item.AudioGenerationStatus == "pending")
                                {
                                    <span class="badge bg-warning text-dark px-2 py-1"><i class="fa-solid fa-spinner fa-spin me-1"></i> Đang xử lý</span>
                                }
                                else if (item.AudioGenerationStatus == "deleted")
                                {
                                    <span class="badge bg-secondary px-2 py-1"><i class="fa-solid fa-trash me-1"></i> Đã xoá</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger px-2 py-1"><i class="fa-solid fa-triangle-exclamation me-1"></i> Lỗi</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (item.AudioGenerationStatus == "generated" || item.AudioGenerationStatus == "cached")
                                {
                                    <audio controls class="me-2" style="height: 30px; width: 200px;">
                                        <source src="@Url.Action("Stream", "Audio", new { id = item.Id })" type="audio/mpeg">
                                        Trình duyệt không hỗ trợ audio.
                                    </audio>
                                }
                                <form asp-action="RegenerateAudio" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary" title="Yêu cầu AI đọc lại">
                                        <i class="fa-solid fa-rotate-right"></i>
                                    </button>
                                </form>
                                <form asp-action="DeleteAudio" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Xoá audio để giải phóng dung lượng">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có kịch bản âm thanh nào trong hệ thống.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
