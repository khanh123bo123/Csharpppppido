@{
    ViewData["Title"] = "Thêm Tài khoản";
}

<div class="card-premium" style="max-width: 600px; margin: 0 auto;">
    <div class="card-header bg-white">
        <h5 class="fw-bold m-0"><i class="fa-solid fa-user-plus text-primary me-2"></i> Tạo User Mới</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-3">
                <label class="form-label fw-semibold">Địa chỉ Email</label>
                <input type="email" name="email" class="form-control" placeholder="user@example.com" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Mật khẩu</label>
                <input type="password" name="password" class="form-control" placeholder="Ít nhất 6 ký tự" required />
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Phân quyền (Role)</label>
                <select name="role" class="form-select" required>
                    <option value="Owner">Chủ Quán (Owner)</option>
                    <option value="Admin">Quản Trị Viên (Admin)</option>
                </select>
                <div class="text-muted small mt-1">Chủ quán chỉ được kiểm soát dữ liệu do chính họ tạo ra.</div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-check me-2"></i>Tạo tài khoản</button>
                <a asp-action="Index" class="btn btn-light border">Hủy thao tác</a>
            </div>
        </form>
    </div>
</div>
