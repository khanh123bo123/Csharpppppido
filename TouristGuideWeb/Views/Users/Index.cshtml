@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityUser>

@{
    ViewData["Title"] = "Quản lý Người dùng";
    var userRolesMap = ViewBag.UserRolesMap as Dictionary<string, IList<string>>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fa-solid fa-users text-primary"></i> Quản lý Người dùng</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-user-plus me-1"></i> Thêm tài khoản</a>
</div>

<div class="card card-premium">
    <div class="card-header bg-white">
        Danh sách tài khoản
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Email / Username</th>
                        <th>Trạng thái Email</th>
                        <th>Vai trò (Roles)</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">Chưa có người dùng nào.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var user in Model)
                        {
                            var roles = userRolesMap != null && userRolesMap.ContainsKey(user.Id) 
                                        ? userRolesMap[user.Id] 
                                        : new List<string>();

                            <tr>
                                <td><small class="text-muted">@user.Id</small></td>
                                <td>
                                    <strong>@user.UserName</strong>
                                    <div class="text-muted" style="font-size: 0.85rem;">@user.Email</div>
                                </td>
                                <td>
                                    @if (user.EmailConfirmed)
                                    {
                                        <span class="badge bg-success">Đã xác nhận</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Chưa xác nhận</span>
                                    }
                                </td>
                                <td>
                                    @if (roles.Any())
                                    {
                                        foreach (var role in roles)
                                        {
                                            <span class="badge bg-primary me-1">@role</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary mb-1">No Role</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary" title="Sửa quyền/Mật khẩu">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    @if(user.Email != "pipizxc05@gmail.com")
                                    {
                                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tài khoản này?');">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
