@{
    ViewData["Title"] = ViewBag.Role == "Admin" ? "Đăng nhập Quản Trị" : "Đăng nhập Chủ Quán";
    ViewData["IsLandingPage"] = true; // Use empty layout
}

<div class="container-fluid p-0">
    <div class="row g-0 min-vh-100">
        <!-- Left Side: Image Background -->
        <div class="col-lg-7 d-none d-lg-flex position-relative align-items-center justify-content-center" style="background: url('/images/login-bg.png') center/cover no-repeat;">
            <!-- Dark Overlay for Readability -->
            <div class="position-absolute top-0 start-0 w-100 h-100" style="background: rgba(44, 76, 59, 0.45);"></div>
            <div class="position-relative text-white text-center px-5" style="z-index: 2;">
                <h1 class="display-3 fw-bold playfair mb-3">Phố Ẩm Thực Vĩnh Khánh</h1>
                <p class="lead fw-medium" style="font-size: 1.25rem;">Hệ thống quản lý nội dung đa ngôn ngữ & Thuyết minh tự động</p>
                <div class="mt-4">
                    <span class="badge bg-light text-dark px-3 py-2 rounded-pill shadow-sm" style="font-size: 0.9rem;">
                        <i class="fa-solid fa-leaf me-1" style="color: #2C4C3B;"></i> Di Sản Ẩm Thực Việt
                    </span>
                </div>
            </div>
        </div>

        <!-- Right Side: Login Form -->
        <div class="col-lg-5 d-flex align-items-center justify-content-center" style="background-color: #FDFBF7;">
            <div class="w-100 p-5 p-md-5" style="max-width: 480px;">
                <div class="mb-5 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center mb-4 shadow-sm" style="width: 64px; height: 64px; border-radius: 16px; background: #B84A39; color: white; font-size: 1.8rem;">
                        <i class="fa-solid @(ViewBag.Role == "Admin" ? "fa-shield-halved" : "fa-store")"></i>
                    </div>
                    <h2 class="fw-bold playfair" style="color: #2C4C3B;">@ViewData["Title"]</h2>
                    <p class="text-muted">Nhập thông tin tài khoản của bạn để tiếp tục</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" style="border-radius: 8px;">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div><i class="fa-solid fa-circle-exclamation"></i> @error.ErrorMessage</div>
                        }
                    </div>
                }

                <form method="post" asp-action="Login">
                    <input type="hidden" name="role" value="@ViewBag.Role" />
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    
                    <div class="mb-4">
                        <label class="form-label text-muted fw-semibold" style="font-size: 0.9rem;">Địa chỉ Email</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white border-end-0 border-light"><i class="fa-regular fa-envelope text-muted"></i></span>
                            <input type="email" name="email" class="form-control border-start-0 ps-0 bg-white border-light" placeholder="@(ViewBag.Role == "Admin" ? "admin@tourguidequan4.com" : "chuquan@example.com")" required style="box-shadow: none;" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted fw-semibold" style="font-size: 0.9rem;">Mật khẩu</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white border-end-0 border-light"><i class="fa-solid fa-lock text-muted"></i></span>
                            <input type="password" name="password" class="form-control border-start-0 ps-0 bg-white border-light" placeholder="••••••••" required style="box-shadow: none;" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mb-5">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="rememberMe" id="rememberMe" value="true" />
                            <label class="form-check-label text-muted" for="rememberMe" style="font-size: 0.95rem;">Ghi nhớ đăng nhập</label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-lg w-100 fw-bold shadow-sm" style="background-color: #B84A39; color: white; border-radius: 12px; transition: all 0.3s;" onmouseover="this.style.backgroundColor='#A33A2A'" onmouseout="this.style.backgroundColor='#B84A39'">
                        Đăng Nhập <i class="fa-solid fa-arrow-right-to-bracket ms-2"></i>
                    </button>
                    
                    @if (ViewBag.Role == "Owner")
                    {
                        <div class="text-center mt-4">
                            <span class="text-muted" style="font-size: 0.95rem;">Chưa có tài khoản?</span>
                            <a href="/Auth/Register" class="text-decoration-none fw-bold ms-1" style="color: #B84A39;">Đăng ký ngay</a>
                        </div>
                    }
                    
                    <div class="text-center mt-5">
                        <a href="/" class="text-decoration-none text-muted" style="font-size: 0.9rem;"><i class="fa-solid fa-arrow-left me-1"></i> Trở về Trang chủ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .border-light { border-color: #EAE3D9 !important; }
    .form-control:focus { border-color: #B84A39 !important; }
    .input-group-text { border-color: #EAE3D9 !important; }
</style>
