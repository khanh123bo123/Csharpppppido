@{
    ViewData["Title"] = "Đổi Mật Khẩu";
}

<div class="card-premium mb-4" style="max-width: 600px; margin: 0 auto; margin-top: 40px;">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
        <h5 class="fw-bold m-0" style="color: #2C4C3B;"><i class="fa-solid fa-key me-2" style="color: #adb5bd;"></i> @ViewData["Title"]</h5>
    </div>
    <div class="card-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger" style="border-radius: 8px;">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div><i class="fa-solid fa-circle-exclamation"></i> @error.ErrorMessage</div>
                }
            </div>
        }

        <form method="post" asp-controller="Auth" asp-action="ChangePassword">
            <div class="mb-3">
                <label class="form-label text-muted fw-semibold" style="font-size: 0.9rem;">Mật khẩu hiện tại</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" name="currentPassword" class="form-control border-start-0 ps-0" placeholder="••••••••" required style="box-shadow: none;" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted fw-semibold" style="font-size: 0.9rem;">Mật khẩu mới</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-key"></i></span>
                    <input type="password" name="newPassword" class="form-control border-start-0 ps-0" placeholder="••••••••" required style="box-shadow: none;" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label text-muted fw-semibold" style="font-size: 0.9rem;">Xác nhận mật khẩu mới</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-check"></i></span>
                    <input type="password" name="confirmPassword" class="form-control border-start-0 ps-0" placeholder="••••••••" required style="box-shadow: none;" />
                </div>
            </div>

            <button type="submit" class="btn btn-premium w-100 py-2 mt-2">
                Đổi mật khẩu
            </button>
        </form>
    </div>
</div>
