@model TouristGuideWeb.Models.DashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";

    var labelsJson = JsonSerializer.Serialize(Model.ProvinceStats.Select(x => x.Province));

    var valuesJson = JsonSerializer.Serialize(Model.ProvinceStats.Select(x => x.Count));
}

<!-- Header Banner -->
<div class="card-premium mb-4">
    <div class="card-body d-flex justify-content-between align-items-center p-4">
        <div class="d-flex align-items-center">
            <div style="font-size: 2rem; color: #adb5bd; margin-right: 15px;">
                <i class="fa-solid fa-chart-column"></i>
            </div>
            <div>
                <h4 class="fw-bold mb-1" style="color: #2C4C3B;">Tổng quan hệ thống</h4>
                <div class="text-muted" style="font-size: 0.9rem;">Quản lý nội dung phố ẩm thực Vĩnh Khánh</div>
            </div>
        </div>
        <div class="text-end">
            <div class="text-muted" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 1px;">CẬP NHẬT LÚC</div>
            <div class="fw-bold" style="font-size: 1.1rem;">@DateTime.Now.ToString("dd/MM/yyyy")</div>
        </div>
    </div>
</div>

<!-- Quick Stats Cards -->
<div class="chevron-container">
    <div class="chevron-wrapper">
        <div class="chevron-card" style="background: linear-gradient(135deg, #6366F1, #4F46E5);">
            <div class="d-flex align-items-center">
                <div class="bg-white p-1 rounded shadow-sm me-3">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=http%3A%2F%2F172.20.10.2%3A5214%2Ftai-app" 
                         alt="Download App" style="width: 60px; height: 60px;" />
                </div>
                <div>
                    <div class="chev-title" style="color: rgba(255,255,255,0.9); font-size: 0.7rem;">CÀI ĐẶT APP</div>
                    <div class="chev-value" style="font-size: 1.1rem; margin-bottom: 2px;">Quét để tải về</div>
                    <a href="/Home/Download" class="text-white small opacity-75 text-decoration-underline">Hướng dẫn</a>
                </div>
            </div>
        </div>
    </div>
    <div class="chevron-wrapper">
        <div class="chevron-card grad-orange">
            <div class="chev-title">QUÁN ĂN</div>
            <div class="chev-value">@Model.TotalLocations</div>
            <div class="chev-desc">Chi tiết quán ăn và<br/>thông tin chi tiết.</div>
        </div>
    </div>
    <div class="chevron-wrapper">
        <div class="chevron-card grad-blue">
            <div class="chev-title">LỘ TRÌNH</div>
            <div class="chev-value">@Model.TotalTours</div>
            <div class="chev-desc">Theo dõi lộ trình khám<br/>phá ẩm thực.</div>
        </div>
    </div>
    <div class="chevron-wrapper">
        <div class="chevron-card grad-green">
            <div class="chev-title">HỘI VIÊN</div>
            <div class="chev-value">@Model.TotalUsers</div>
            <div class="chev-desc">Số tài khoản đăng ký<br/>qua ứng dụng di động.</div>
        </div>
    </div>
        <div class="chevron-card grad-purple">
            <div class="chev-title">LƯỢT NGHE TTS</div>
            <div class="chev-value" id="listen-count-value">@Model.TotalAudios</div>
            <div class="chev-desc">Lượt thuyết minh tự<br/>động.</div>
        </div>
    </div>
    <div class="chevron-wrapper">
        <div class="chevron-card grad-cyan">
            <div class="chev-title">ĐANG ONLINE</div>
            <div class="chev-value" id="online-count-value">@Model.OnlineDevicesCount</div>
            <div class="chev-desc">Thiết bị đang hoạt động<br/>trong 5 phút qua.</div>
        </div>
    </div>
</div>

<!-- Recent Ratings Section -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card-premium">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0 text-dark-blue">
                        <i class="fa-solid fa-star text-warning me-2"></i>Đánh giá mới nhất
                    </h5>
                    <span class="badge bg-light text-muted">Hiển thị 50 lượt gần nhất</span>
                </div>
                
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 200px;">Quán ăn / POI</th>
                                <th style="width: 120px;">Đánh giá</th>
                                <th>Người đánh giá</th>
                                <th style="width: 180px;">Thời gian</th>
                                <th style="width: 150px;">Địa chỉ IP / Thiết bị</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentRatings == null || !Model.RecentRatings.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted italic">Chưa có đánh giá nào được ghi nhận.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var rating in Model.RecentRatings)
                                {
                                    <tr>
                                        <td class="fw-bold">@rating.LocationName</td>
                                        <td>
                                            <div class="text-warning">
                                                @for (int i = 0; i < 5; i++)
                                                {
                                                    <i class="fa-@(i < rating.Stars ? "solid" : "regular") fa-star"></i>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(rating.UserEmail))
                                            {
                                                <span class="badge bg-primary">@rating.UserEmail</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Khách vãng lai</span>
                                            }
                                        </td>
                                        <td class="text-muted small">@rating.RatedAt.AddHours(7).ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="small">
                                            <div class="text-truncate" style="max-width: 140px;" title="@rating.UserIp / @rating.DeviceIdentifier">
                                                @(rating.UserIp ?? "N/A")
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Lower Section -->
<div class="row g-4 mb-4">
    <!-- Left Column: Owner Info & Chart -->
    <div class="col-md-7">
        <!-- Owner Info -->
        <div class="card-premium mb-4">
            <div class="card-body">
                <div class="row text-center align-items-center">
                    <div class="col-4 border-end">
                        <div class="mb-2 text-start fw-bold fs-5 text-dark-blue">Chủ quán & POI</div>
                        <div class="mx-auto mt-4" style="width: 70px; height: 70px; border-radius: 50%; background: #e0e0e0; display: flex; align-items: center; justify-content: center; font-size: 1.8rem;">
                            <img src="https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "A")&background=random" style="width:100%; height:100%; border-radius:50%; object-fit:cover;" />
                        </div>
                        <div class="mt-2 fw-bold text-dark-blue fs-5">@(User.Identity?.Name ?? "owner99")</div>
                        <div class="text-muted" style="font-size: 0.85rem;">@(User.IsInRole("Owner") ? "1 quán" : "Quản trị viên")</div>
                    </div>
                    <div class="col-4 border-end d-flex flex-column justify-content-center">
                        <div style="font-size: 2rem; color: #ff6b35;"><i class="fa-solid fa-store"></i></div>
                        <div class="fs-1 fw-bold mt-2 text-dark-blue">@Model.TotalLocations</div>
                        <div class="text-muted fw-bold" style="font-size: 0.9rem;">QUÁN</div>
                    </div>
                    <div class="col-4 d-flex flex-column justify-content-center">
                        <div style="font-size: 2rem; color: #3b82f6;"><i class="fa-solid fa-map-location-dot"></i></div>
                        <div class="fs-1 fw-bold mt-2 text-dark-blue">@Model.TotalLocations</div>
                        <div class="text-muted fw-bold" style="font-size: 0.9rem;">POI</div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Right Column: Quick Actions -->
    <div class="col-md-5">
        <h5 class="fw-bold mb-3 text-dark-blue">Thao Tác Nhanh</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <a asp-controller="Locations" asp-action="Create" class="action-card grad-orange" style="height: 140px;">
                    <i class="fa-solid fa-utensils icon-top-right"></i>
                    <div class="action-title">Thêm quán ăn</div>
                    <div class="action-desc">Quản lý quán ăn và chi tiết.</div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Tours" asp-action="Create" class="action-card grad-blue" style="height: 140px;">
                    <i class="fa-regular fa-compass icon-top-right"></i>
                    <div class="action-title">Tạo lộ trình</div>
                    <div class="action-desc">Quản lý thông tin quán ăn, upload audio.</div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Locations" asp-action="Index" class="action-card" style="background: linear-gradient(135deg, #A855F7, #3B82F6); height: 140px;">
                    <i class="fa-solid fa-map-location icon-top-right"></i>
                    <div class="action-title">Quản lý chính</div>
                    <div class="action-desc">Quản lý thông tin quán ăn và bản đồ.</div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Tours" asp-action="Index" class="action-card grad-green" style="height: 140px;">
                    <i class="fa-solid fa-list-check icon-top-right"></i>
                    <div class="action-title">Quản lý lộ trình</div>
                    <div class="action-desc">Quản lý thông tin và các địa điểm.</div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Localizations" asp-action="Index" class="action-card" style="background: linear-gradient(135deg, #10B981, #059669); height: 140px;">
                    <i class="fa-solid fa-globe icon-top-right"></i>
                    <div class="action-title">Quản lý ngôn ngữ</div>
                    <div class="action-desc">Quản lý bản dịch và đa ngôn ngữ.</div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Statistics" asp-action="Index" class="action-card" style="background: linear-gradient(135deg, #D946EF, #9333EA); height: 140px;">
                    <i class="fa-regular fa-file-lines icon-top-right"></i>
                    <div class="action-title">Thống kê chi tiết</div>
                    <div class="action-desc">Theo dõi lượt thuyết minh tự động.</div>
                </a>
            </div>
        </div>
    </div>
</div>



@section Scripts {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const labels = @Html.Raw(labelsJson);
                const data = @Html.Raw(valuesJson);

            });

            // Online Count Refresh logic
            function refreshOnlineCount() {
                fetch('/Dashboard/GetOnlineCount')
                    .then(response => response.json())
                    .then(data => {
                        const el = document.getElementById('online-count-value');
                        if (el && data && typeof data.onlineCount !== 'undefined') {
                            const current = parseInt(el.innerText);
                            if (current !== data.onlineCount) {
                                el.innerText = data.onlineCount;
                                el.style.transition = 'transform 0.2s';
                                el.style.transform = 'scale(1.2)';
                                setTimeout(() => el.style.transform = 'scale(1)', 200);
                            }
                        }
                    })
                    .catch(err => console.error('Error refreshing online count:', err));
            }

            function refreshListenStats() {
                fetch('/Dashboard/GetListenStats')
                    .then(response => response.json())
                    .then(data => {
                        const el = document.getElementById('listen-count-value');
                        if (el && data && typeof data.totalListens !== 'undefined') {
                            const current = parseInt(el.innerText);
                            if (current !== data.totalListens) {
                                el.innerText = data.totalListens;
                                el.style.transition = 'transform 0.2s';
                                el.style.transform = 'scale(1.2)';
                                setTimeout(() => el.style.transform = 'scale(1)', 200);
                            }
                        }
                    })
                    .catch(err => console.error('Error refreshing listen stats:', err));
            }

            setInterval(refreshOnlineCount, 10000); // Every 10 seconds
            setInterval(refreshListenStats, 10000); // Every 10 seconds
        </script>
}
