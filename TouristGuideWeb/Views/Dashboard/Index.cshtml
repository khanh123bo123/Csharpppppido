@model TouristGuideWeb.Models.DashboardViewModel
@using System.Text.Json
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Dashboard";

    var labelsJson = JsonSerializer.Serialize(Model.ProvinceStats.Select(x => x.Province));

    var valuesJson = JsonSerializer.Serialize(Model.ProvinceStats.Select(x => x.Count));
}

<!-- Header Banner -->
<div class="card-premium mb-4">
    <div class="card-body d-flex justify-content-between align-items-center p-4">
        <div class="d-flex align-items-center">
            <div style="font-size: 2rem; color: #adb5bd; margin-right: 15px;">
                <i class="fa-solid fa-chart-column"></i>
            </div>
            <div>
                <h4 class="fw-bold mb-1" style="color: #2C4C3B;">Tổng quan hệ thống</h4>
                <div class="text-muted" style="font-size: 0.9rem;">Quản lý nội dung phố ẩm thực Vĩnh Khánh</div>
            </div>
        </div>
        <div class="text-end">
            <div class="text-muted" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 1px;">CẬP NHẬT LÚC</div>
            <div class="fw-bold" style="font-size: 1.1rem;">@DateTime.Now.ToString("dd/MM/yyyy")</div>
        </div>
    </div>
</div>

<!-- 4 Statistical Cards (Chevron Style) -->
<div class="chevron-container">
    <div class="chevron-wrapper">
        <div class="chevron-card grad-orange">
            <div class="chev-title">QUÁN ĂN</div>
            <div class="chev-value">@Model.TotalLocations</div>
            <div class="chev-desc">Chi tiết quán ăn và<br/>thông tin chi tiết.</div>
        </div>
    </div>
    <div class="chevron-wrapper">
        <div class="chevron-card grad-blue">
            <div class="chev-title">LỘ TRÌNH</div>
            <div class="chev-value">@Model.TotalTours</div>
            <div class="chev-desc">Theo dõi lộ trình khám<br/>phá ẩm thực.</div>
        </div>
    </div>
    <div class="chevron-wrapper">
        <div class="chevron-card grad-green">
            <div class="chev-title">KHÁCH ĐANG ONLINE</div>
            <div class="chev-value" id="onlineUsersCount">0</div>
            <div class="chev-desc"><span id="onlineDevicesCount">0</span> thiết bị<br/>đang hoạt động.</div>
        </div>
    </div>
    <div class="chevron-wrapper">
        <div class="chevron-card grad-purple">
            <div class="chev-title">LƯỢT NGHE TTS</div>
            <div class="chev-value">@Model.TotalAudios</div>
            <div class="chev-desc">Lượt thuyết minh tự<br/>động.</div>
        </div>
    </div>
</div>

<!-- Lower Section -->
<div class="row g-4 mb-4">
    <!-- Left Column: Owner Info & Chart -->
    <div class="col-md-7">
        <!-- Owner Info -->
        <div class="card-premium mb-4">
            <div class="card-body">
                <div class="row text-center align-items-center">
                    <div class="col-4 border-end">
                        <div class="mb-2 text-start fw-bold fs-5 text-dark-blue">Chủ quán & POI</div>
                        <div class="mx-auto mt-4" style="width: 70px; height: 70px; border-radius: 50%; background: #e0e0e0; display: flex; align-items: center; justify-content: center; font-size: 1.8rem;">
                            <img src="https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "A")&background=random" style="width:100%; height:100%; border-radius:50%; object-fit:cover;" />
                        </div>
                        <div class="mt-2 fw-bold text-dark-blue fs-5">@(User.Identity?.Name ?? "owner99")</div>
                        <div class="text-muted" style="font-size: 0.85rem;">@(User.IsInRole("Owner") ? "1 quán" : "Quản trị viên")</div>
                    </div>
                    <div class="col-4 border-end d-flex flex-column justify-content-center">
                        <div style="font-size: 2rem; color: #ff6b35;"><i class="fa-solid fa-store"></i></div>
                        <div class="fs-1 fw-bold mt-2 text-dark-blue">@Model.TotalLocations</div>
                        <div class="text-muted fw-bold" style="font-size: 0.9rem;">QUÁN</div>
                    </div>
                    <div class="col-4 d-flex flex-column justify-content-center">
                        <div style="font-size: 2rem; color: #3b82f6;"><i class="fa-solid fa-map-location-dot"></i></div>
                        <div class="fs-1 fw-bold mt-2 text-dark-blue">@Model.TotalLocations</div>
                        <div class="text-muted fw-bold" style="font-size: 0.9rem;">POI</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chart -->
        <div class="card-premium mb-0" style="height: 280px;">
            <div class="card-body h-100">
                <div class="h-100 w-100">
                    <canvas id="provinceChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Quick Actions -->
    <div class="col-md-5">
        <h5 class="fw-bold mb-3 text-dark-blue">Thao Tác Nhanh</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <a asp-controller="Locations" asp-action="Create" class="action-card grad-orange" style="height: 140px;">
                    <i class="fa-solid fa-utensils icon-top-right"></i>
                    <div class="action-title">Thêm quán ăn</div>
                    <div class="action-desc">Quản lý quán ăn và chi tiết.</div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Tours" asp-action="Create" class="action-card grad-blue" style="height: 140px;">
                    <i class="fa-regular fa-compass icon-top-right"></i>
                    <div class="action-title">Tạo lộ trình</div>
                    <div class="action-desc">Quản lý thông tin quán ăn, upload audio.</div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Locations" asp-action="Index" class="action-card" style="background: linear-gradient(135deg, #A855F7, #3B82F6); height: 140px;">
                    <i class="fa-solid fa-map-location icon-top-right"></i>
                    <div class="action-title">Quản lý trưởng</div>
                    <div class="action-desc">Quản lý thông tin quán ăn, bản án.</div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Tours" asp-action="Index" class="action-card grad-green" style="height: 140px;">
                    <i class="fa-solid fa-list-check icon-top-right"></i>
                    <div class="action-title">Tạo lộ trình</div>
                    <div class="action-desc">Quản lý thông tin và bá đính.</div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Localizations" asp-action="Index" class="action-card" style="background: linear-gradient(135deg, #10B981, #059669); height: 140px;">
                    <i class="fa-solid fa-globe icon-top-right"></i>
                    <div class="action-title">Quản lý ngôn ngữ</div>
                    <div class="action-desc">Quản lý phòng đón và ngôn ngữ.</div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Statistics" asp-action="Index" class="action-card" style="background: linear-gradient(135deg, #D946EF, #9333EA); height: 140px;">
                    <i class="fa-regular fa-file-lines icon-top-right"></i>
                    <div class="action-title">Báo cáo chi tiết</div>
                    <div class="action-desc">Lượt lý thuyết minh tự động.</div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-controller="Apk" asp-action="Index" class="action-card" style="background: linear-gradient(135deg, #1D4ED8, #0EA5E9); height: 140px;">
                    <i class="fa-solid fa-qrcode icon-top-right"></i>
                    <div class="action-title">QR tải ứng dụng</div>
                    <div class="action-desc">Quét QR để tải APK mới nhất.</div>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card-premium" style="height: 320px;">
            <div class="card-body h-100 d-flex flex-column">
                <h6 class="fw-bold mb-3 text-dark-blue">Audio Nghe Nhiều Nhất</h6>
                <div style="flex-grow: 1; position: relative;">
                    <canvas id="topAudiosChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card-premium" style="height: 320px;">
            <div class="card-body h-100 d-flex flex-column">
                <h6 class="fw-bold mb-3 text-dark-blue">Thời Gian Khách Dùng Nhiều Nhất (Theo giờ)</h6>
                <div style="flex-grow: 1; position: relative;">
                    <canvas id="playsByHourChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script>
            const labels = @Html.Raw(labelsJson);
            const data = @Html.Raw(valuesJson);

            const ctx = document.getElementById('provinceChart');
            if (ctx) {
                Chart.defaults.color = "#627d98";
                Chart.defaults.borderColor = "rgba(0, 0, 0, 0.05)";

                if (labels.length === 0) {
                    const canvas = document.getElementById('provinceChart');
                    const parent = canvas.parentElement;
                    parent.innerHTML = `<div style="height:100%; display:flex; align-items:center; justify-content:center; color:#adb5bd; flex-direction:column; gap:8px;">
                        <i class="fa-solid fa-chart-bar" style="font-size:2rem; opacity:0.4;"></i>
                        <span style="font-size:0.9rem;">Chưa có dữ liệu thống kê</span>
                    </div>`;
                } else {
                    new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: 'Số quán',
                                data: data,
                                borderWidth: 0,
                                backgroundColor: 'rgba(255, 107, 53, 0.8)',
                                borderRadius: 6
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    ticks: { precision: 0 },
                                    grid: { color: "rgba(0, 0, 0, 0.04)" }
                                },
                                x: {
                                    grid: { display: false }
                                }
                            },
                            plugins: {
                                legend: { display: false }
                            }
                        }
                    });
                }
            }
            
            // SignalR Setup for Online Users
            const apiBaseUrl = "@Configuration["ApiSettings:BaseUrl"]".replace(/\/$/, "");
            const connection = new signalR.HubConnectionBuilder()
                .withUrl(apiBaseUrl + "/apphub?source=web")
                .withAutomaticReconnect()
                .build();

            connection.on("UpdateOnlineUsers", function (stats) {
                document.getElementById("onlineUsersCount").innerText = stats.totalUniqueUsers;
                document.getElementById("onlineDevicesCount").innerText = stats.totalConnections;
            });

            connection.start().then(function () {
                // Ask for initial stats
                connection.invoke("GetOnlineUsers").catch(function (err) {
                    return console.error(err.toString());
                });
            }).catch(function (err) {
                return console.error(err.toString());
            });

            // Fetch Dashboard Statistics
            fetch(apiBaseUrl + "/api/Statistics/dashboard")
                .then(res => res.json())
                .then(stats => {
                    // Top Audios Chart
                    const topAudiosCtx = document.getElementById('topAudiosChart');
                    if (topAudiosCtx && stats.topAudios.length > 0) {
                        const audioLabels = stats.topAudios.map(a => {
                            let name = a.locationName.length > 20 ? a.locationName.substring(0, 20) + '...' : a.locationName;
                            return name + ' (' + a.languageCode + ')';
                        });
                        const audioData = stats.topAudios.map(a => a.playCount);

                        new Chart(topAudiosCtx, {
                            type: 'bar',
                            data: {
                                labels: audioLabels,
                                datasets: [{
                                    label: 'Lượt nghe',
                                    data: audioData,
                                    backgroundColor: 'rgba(59, 130, 246, 0.8)',
                                    borderRadius: 6
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: { legend: { display: false } },
                                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                            }
                        });
                    } else if (topAudiosCtx) {
                         topAudiosCtx.parentElement.innerHTML = `<div style="height:100%; display:flex; align-items:center; justify-content:center; color:#adb5bd; flex-direction:column; gap:8px;"><i class="fa-solid fa-chart-bar" style="font-size:2rem; opacity:0.4;"></i><span style="font-size:0.9rem;">Chưa có dữ liệu thống kê</span></div>`;
                    }

                    // Plays By Hour Chart
                    const hoursCtx = document.getElementById('playsByHourChart');
                    if (hoursCtx && stats.playsByHour.some(v => v > 0)) {
                        const hourLabels = Array.from({length: 24}, (_, i) => i + ':00');
                        
                        new Chart(hoursCtx, {
                            type: 'line',
                            data: {
                                labels: hourLabels,
                                datasets: [{
                                    label: 'Lượt nghe',
                                    data: stats.playsByHour,
                                    borderColor: 'rgba(16, 185, 129, 1)',
                                    backgroundColor: 'rgba(16, 185, 129, 0.2)',
                                    fill: true,
                                    tension: 0.4
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: { legend: { display: false } },
                                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                            }
                        });
                    } else if (hoursCtx) {
                         hoursCtx.parentElement.innerHTML = `<div style="height:100%; display:flex; align-items:center; justify-content:center; color:#adb5bd; flex-direction:column; gap:8px;"><i class="fa-solid fa-chart-line" style="font-size:2rem; opacity:0.4;"></i><span style="font-size:0.9rem;">Chưa có dữ liệu thống kê</span></div>`;
                    }
                })
                .catch(err => console.error("Error fetching statistics:", err));
        </script>
}
