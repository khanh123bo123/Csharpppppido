@model TouristGuideWeb.Models.DashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";
    var labelsJson = JsonSerializer.Serialize(Model.ProvinceStats.Select(x => x.Province));
    var valuesJson = JsonSerializer.Serialize(Model.ProvinceStats.Select(x => x.Count));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Dashboard</h2>
    <a asp-controller="Locations" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fa-solid fa-table-list me-1"></i>Quan ly dia diem
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted">Tong so dia diem</div>
                <div class="display-6 fw-bold">@Model.TotalLocations</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted">So tinh/thanh (suy luan)</div>
                <div class="display-6 fw-bold">@Model.ProvinceStats.Count</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted">Moc trung tam</div>
                <div class="h5 mb-0 fw-bold">Ha Noi</div>
                <small class="text-muted">Lat 21.027763, Lng 105.83416</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Phan bo dia diem theo tinh/thanh</div>
            <div class="card-body">
                <canvas id="provinceChart" height="240"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">5 dia diem gan Ha Noi nhat</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Ten</th>
                                <th>Toa do</th>
                                <th>Khoang cach</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.NearestToHanoi)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Locations" asp-action="Details" asp-route-id="@item.Id">@item.Name</a>
                                    </td>
                                    <td>@item.Latitude.ToString("0.####"), @item.Longitude.ToString("0.####")</td>
                                    <td>@item.DistanceKm.ToString("0.##") km</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script>
        const labels = @Html.Raw(labelsJson);
        const data = @Html.Raw(valuesJson);

        const ctx = document.getElementById('provinceChart');
        if (ctx) {
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels,
                    datasets: [{
                        label: 'So dia diem',
                        data,
                        borderWidth: 1,
                        backgroundColor: '#0d6efd80',
                        borderColor: '#0d6efd'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0
                            }
                        }
                    }
                }
            });
        }
    </script>
}
