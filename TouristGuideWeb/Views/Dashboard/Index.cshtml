@model TouristGuideWeb.Models.DashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";
    var labelsJson = JsonSerializer.Serialize(Model.ProvinceStats.Select(x => x.Province));
    var valuesJson = JsonSerializer.Serialize(Model.ProvinceStats.Select(x => x.Count));
}

<!-- Header Banner -->
<div class="card-premium mb-4">
    <div class="card-body d-flex justify-content-between align-items-center p-4">
        <div class="d-flex align-items-center">
            <div style="font-size: 2rem; color: #adb5bd; margin-right: 15px;">
                <i class="fa-solid fa-chart-column"></i>
            </div>
            <div>
                <h4 class="fw-bold mb-1" style="color: #333;">Tổng quan hệ thống</h4>
                <div class="text-muted" style="font-size: 0.9rem;">Quản lý nội dung phố ẩm thực Vĩnh Khánh</div>
            </div>
        </div>
        <div class="text-end">
            <div class="text-muted" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 1px;">CẬP NHẬT LÚC</div>
            <div class="fw-bold" style="font-size: 1.1rem;">@DateTime.Now.ToString("dd/MM/yyyy")</div>
        </div>
    </div>
</div>

<!-- 4 Statistical Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card bg-orange">
            <i class="fa-solid fa-utensils stat-icon"></i>
            <div class="stat-title">QUÁN ĂN</div>
            <div class="stat-value">@Model.TotalLocations</div>
            <div class="stat-subtitle">Đang hoạt động</div>
            <div class="stat-desc">Các quán ăn đã được đăng ký trên hệ thống</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-blue">
            <i class="fa-solid fa-route stat-icon"></i>
            <div class="stat-title">LỘ TRÌNH</div>
            <div class="stat-value">@Model.TotalTours</div>
            <div class="stat-subtitle">Đang mở</div>
            <div class="stat-desc">Lộ trình khám phá ẩm thực cho du khách</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-green">
            <i class="fa-solid fa-users stat-icon"></i>
            <div class="stat-title">KHÁCH THAM QUAN</div>
            <div class="stat-value">4</div>
            <div class="stat-subtitle">Tổng lượt đăng ký</div>
            <div class="stat-desc">Lượt du khách sử dụng ứng dụng</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-pink">
            <i class="fa-solid fa-headphones stat-icon"></i>
            <div class="stat-title">LƯỢT NGHE TTS</div>
            <div class="stat-value">@Model.TotalAudios</div>
            <div class="stat-subtitle">Số bản dịch audio AI</div>
            <div class="stat-desc">Lượt thuyết minh tự động đã phát</div>
        </div>
    </div>
</div>

<!-- Owner Information -->
<div class="card-premium mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
        <h5 class="fw-bold m-0" style="color: #333;"><i class="fa-solid fa-user-group me-2" style="color: #adb5bd;"></i> Chủ quán & số POI</h5>
    </div>
    <div class="card-body">
        <div class="d-inline-flex align-items-center p-3" style="background: #f8f9fa; border-radius: 12px; border: 1px solid #eaeaea; min-width: 200px;">
            <div class="me-3" style="width: 40px; height: 40px; border-radius: 50%; background: #ffe4cc; color: #ff5722; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.2rem;">
                O
            </div>
            <div>
                <div class="fw-bold" style="color: #333; font-size: 1rem;">owner99</div>
                <div class="text-muted" style="font-size: 0.85rem;">1 quán</div>
            </div>
        </div>
    </div>
</div>

<!-- Lower Section -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card-premium h-100 mb-0">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h5 class="fw-bold m-0" style="color: #333;"><i class="fa-solid fa-user-gear me-2" style="color: #adb5bd;"></i> Thao tác nhanh</h5>
            </div>
            <div class="card-body">
                <a asp-controller="Locations" asp-action="Create" class="quick-action-btn">
                    Thêm quán ăn
                </a>
                <a href="#" class="quick-action-btn">
                    Tạo lộ trình
                </a>
                <a href="#" class="quick-action-btn">
                    Quản lý ngôn ngữ
                </a>
                <a href="#" class="quick-action-btn">
                    Báo cáo chi tiết
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card-premium h-100 mb-0">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold m-0" style="color: #333;"><i class="fa-solid fa-chart-line me-2" style="color: #adb5bd;"></i> Top địa điểm được lắng nghe</h5>
                <span class="badge bg-light text-dark border">30 NGÀY QUA</span>
            </div>
            <div class="card-body pb-4">
                <div style="background: #ffffff; border: 1px solid #eaeaea; border-radius: 12px; padding: 20px; height: 260px; box-shadow: 0 4px 15px rgba(0,0,0,0.02);">
                    <canvas id="provinceChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const labels = @Html.Raw(labelsJson);
        const data = @Html.Raw(valuesJson);

        const ctx = document.getElementById('provinceChart');
        if (ctx) {
            Chart.defaults.color = "#627d98";
            Chart.defaults.borderColor = "rgba(0, 0, 0, 0.05)";
            
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels.length > 0 ? labels : ['Quán Cơm Tấm Ba Ghiền', 'Bún Bò Huế', 'Ốc Oanh', 'Hủ Tiếu Nam Vang'],
                    datasets: [{
                        label: 'Số lần nghe',
                        data: data.length > 0 ? data : [1, 0.5, 0.25, 0.8],
                        borderWidth: 0,
                        backgroundColor: '#ff6b35',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 2
                            },
                            grid: {
                                color: "rgba(0, 0, 0, 0.05)"
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        }
                    }
                }
            });
        }
    </script>
}
