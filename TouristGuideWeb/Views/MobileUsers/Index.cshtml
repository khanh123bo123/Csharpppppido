@model IEnumerable<TouristGuideWeb.Services.MobileUserModel>

@{
    ViewData["Title"] = "Quản lý Hội viên (App Mobile)";
}

<div class="card-premium mb-4">
    <div class="card-body d-flex justify-content-between align-items-center p-4">
        <div class="d-flex align-items-center">
            <div style="font-size: 2rem; color: #adb5bd; margin-right: 15px;">
                <i class="fa-solid fa-users-gear"></i>
            </div>
            <div>
                <h4 class="fw-bold mb-1" style="color: #2C4C3B;">Quản lý Hội viên</h4>
                <div class="text-muted" style="font-size: 0.9rem;">Danh sách người dùng đăng ký qua ứng dụng Mobile</div>
            </div>
        </div>
        <div class="text-end">
            <div class="text-muted" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 1px;">TỔNG CỘNG</div>
            <div class="fw-bold" style="font-size: 1.5rem; color: #B84A39;">@Model.Count()</div>
        </div>
    </div>
</div>

<div class="card-premium">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead style="background-color: #f8f9fa;">
                    <tr>
                        <th class="ps-4 py-3">Họ và Tên</th>
                        <th class="py-3">Email</th>
                        <th class="py-3">Vai trò</th>
                        <th class="py-3">ID</th>
                        <th class="pe-4 py-3 text-end">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; border: 1px solid #eee;">
                                        <i class="fa-solid fa-user text-muted"></i>
                                    </div>
                                    <span class="fw-bold">@user.FullName</span>
                                </div>
                            </td>
                            <td class="py-3">@user.Email</td>
                            <td class="py-3">
                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary")">@user.Role</span>
                            </td>
                            <td class="py-3"><code class="text-muted">#@user.Id</code></td>
                            <td class="pe-4 py-3 text-end">
                                <span class="text-success"><i class="fa-solid fa-circle-check me-1"></i>Hoạt động</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <div class="text-muted mb-2"><i class="fa-solid fa-user-slash fs-1"></i></div>
        <p class="text-muted">Chưa có người dùng nào đăng ký qua Mobile App.</p>
    </div>
}
