@model TouristGuideWeb.Models.Tour
@{
    ViewData["Title"] = "Sửa Lộ Trình";
}

<div class="card-premium">
    <div class="card-header bg-white">
        <h5 class="fw-bold m-0"><i class="fa-solid fa-pen text-primary me-2"></i> Chỉnh sửa Lộ Trình</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Tên Lộ Trình</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="EstimatedDurationMinutes" class="form-label fw-semibold">Thời lượng (phút)</label>
                    <input asp-for="EstimatedDurationMinutes" type="number" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="EstimatedDistanceKm" class="form-label fw-semibold">Khoảng cách (km)</label>
                    <input asp-for="EstimatedDistanceKm" type="number" step="0.1" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-4 form-check form-switch">
                <input class="form-check-input" type="checkbox" asp-for="IsActive">
                <label class="form-check-label" asp-for="IsActive">Kích hoạt hiển thị</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-save me-2"></i>Cập nhật</button>
                <a asp-action="Index" class="btn btn-light border">Hủy thao tác</a>
            </div>
        </form>
    </div>
</div>
