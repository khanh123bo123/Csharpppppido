@model TouristGuideWeb.Models.TourDetailsViewModel

@{
    ViewData["Title"] = "Biên tập Lộ Trình";
}

<div class="row align-items-center mb-4">
    <div class="col-md-6">
        <h2 class="fw-bold text-gray-900 mb-0">Biên tập: @Model.CurrentTour.Name</h2>
        <p class="text-muted mt-2">@Model.CurrentTour.Description | <span class="fw-bold text-primary">@Model.CurrentTour.EstimatedDistanceKm km</span></p>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Index" class="btn btn-light shadow-sm rounded-pill px-4 btn-hover-elevate">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <!-- Cột trái: Quản lý Quán ăn đã thêm trong Lộ Trình -->
    <div class="col-lg-8 mb-4">
        <div class="card premium-card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h5 class="fw-bold text-gray-800"><i class="bi bi-map text-primary me-2"></i> Các điểm dừng chân trong Lộ trình</h5>
            </div>
            <div class="card-body">
                @if (Model.AssignedLocations.Any())
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col" class="rounded-start">Thứ tự</th>
                                    <th scope="col">Tên Quán / Địa điểm</th>
                                    <th scope="col" class="text-end rounded-end">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tl in Model.AssignedLocations.OrderBy(x => x.OrderIndex))
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-primary rounded-circle p-2 fs-6">@tl.OrderIndex</span>
                                        </td>
                                        <td>
                                            <div class="fw-bold text-gray-900">@tl.Location?.Name</div>
                                            <div class="text-muted small">@tl.Location?.Category</div>
                                        </td>
                                        <td class="text-end">
                                            <form asp-action="RemoveLocation" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@Model.CurrentTour.Id" />
                                                <input type="hidden" name="locationId" value="@tl.LocationId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle" onclick="return confirm('Gỡ điểm này khỏi lộ trình?');" title="Gỡ ra">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-signpost-split text-muted fs-1"></i>
                        </div>
                        <h6 class="fw-bold text-muted">Chưa có trạm dừng nào</h6>
                        <p class="text-muted small">Hãy thêm các quán ăn vào lộ trình bằng bảng bên phải.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Cột phải: Thêm mới Quán ăn vào Lộ Trình -->
    <div class="col-lg-4 mb-4">
        <div class="card premium-card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h5 class="fw-bold text-gray-800"><i class="bi bi-plus-circle text-success me-2"></i> Thêm Địa điểm</h5>
            </div>
            <div class="card-body">
                @if (Model.AvailableLocations.Any())
                {
                    <form asp-action="AddLocation" method="post">
                        <input type="hidden" name="id" value="@Model.CurrentTour.Id" />
                        
                        <div class="mb-4">
                            <label class="form-label text-gray-700 fw-bold">Chọn quán để thêm vào lộ trình:</label>
                            <select name="locationId" class="form-select form-select-lg rounded-3 border-light bg-light" required>
                                <option value="" disabled selected>-- Bấm để chọn quán --</option>
                                @foreach (var loc in Model.AvailableLocations)
                                {
                                    <option value="@loc.Id">@loc.Name (@loc.Category)</option>
                                }
                            </select>
                        </div>
                        
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary rounded-pill py-2 btn-hover-elevate fw-bold">
                                <i class="bi bi-plus-lg me-1"></i> Gắn vào Tuyến
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="alert alert-info rounded-4 border-0">
                        <i class="bi bi-info-circle-fill me-2"></i> Không còn địa điểm trống nào để thêm.
                    </div>
                }
            </div>
        </div>
    </div>
</div>
