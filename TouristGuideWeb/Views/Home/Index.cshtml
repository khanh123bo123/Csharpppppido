@{
    ViewData["Title"] = "Welcome";
    ViewData["IsLandingPage"] = true;
}
<div class="landing-container d-flex flex-column align-items-center justify-content-center min-vh-100" style="background: linear-gradient(135deg, #f0f4f8 0%, #d9e2ec 100%); font-family: 'Inter', sans-serif;">
    <div class="text-center mb-5">
        <div class="mb-3 d-flex justify-content-center">
            <div style="background: linear-gradient(145deg, #ff6b35, #ff4e00); color: #fff; width: 64px; height: 64px; display: flex; align-items: center; justify-content: center; border-radius: 18px; font-size: 28px; box-shadow: 0 8px 24px rgba(255, 87, 34, 0.3);">
                <i class="fa-solid fa-bowl-food px-1"></i>
            </div>
        </div>
        <h1 class="fw-bold" style="color: #102a43; font-size: 3rem; letter-spacing: -0.5px; margin-bottom: 10px;">Phố Ẩm Thực Vĩnh Khánh</h1>
        <p class="fs-5" style="color: #627d98;">Hệ thống quản lý thuyết minh tự động đa ngôn ngữ</p>
    </div>

    <div class="d-flex flex-column flex-md-row gap-4 mt-2" style="max-width: 900px; width: 100%; padding: 0 20px;">
        <!-- Admin Card -->
        <div class="card flex-fill role-card">
            <div class="card-body p-5">
                <div class="mb-4">
                    <div style="width: 54px; height: 54px; border-radius: 14px; background: rgba(255, 107, 53, 0.1); display: flex; align-items: center; justify-content: center; color: #ff6b35; font-size: 1.6rem;">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>
                </div>
                <h3 class="fw-bold" style="color: #102a43; font-size: 1.5rem;">Quản Trị Viên</h3>
                <p class="mt-3 mb-4" style="font-size: 0.95rem; line-height: 1.6; color: #627d98;">
                    Quản lý toàn bộ hệ thống: POI, Tour, Analytics, Người dùng, Cấu hình hệ thống.
                </p>
                <a href="/Auth/Login?role=Admin" class="text-decoration-none fw-semibold" style="color: #ff6b35; font-size: 0.95rem; display: flex; align-items: center; gap: 8px;">
                    Đăng nhập Admin <i class="fa-solid fa-arrow-right transition-transform"></i>
                </a>
            </div>
        </div>

        <!-- Owner Card -->
        <div class="card flex-fill role-card">
            <div class="card-body p-5">
                <div class="mb-4">
                    <div style="width: 54px; height: 54px; border-radius: 14px; background: rgba(16, 185, 129, 0.1); display: flex; align-items: center; justify-content: center; color: #10b981; font-size: 1.6rem;">
                        <i class="fa-solid fa-store"></i>
                    </div>
                </div>
                <h3 class="fw-bold" style="color: #102a43; font-size: 1.5rem;">Chủ Quán</h3>
                <p class="mt-3 mb-4" style="font-size: 0.95rem; line-height: 1.6; color: #627d98;">
                    Quản lý thông tin quán ăn, upload audio, chỉnh sửa mô tả và bản dịch.
                </p>
                <a href="/Auth/Login?role=Owner" class="text-decoration-none fw-semibold" style="color: #10b981; font-size: 0.95rem; display: flex; align-items: center; gap: 8px;">
                    Đăng nhập / Đăng ký <i class="fa-solid fa-arrow-right transition-transform"></i>
                </a>
            </div>
        </div>
    </div>
    
    <div class="mt-5" style="font-size: 0.9rem; color: #829ab1;">
        &copy; 2026 Phố Ẩm Thực Vĩnh Khánh &mdash; Quận 4, TP. Hồ Chí Minh
    </div>
</div>

<style>
    .role-card {
        background: #ffffff !important;
        border: 1px solid rgba(0, 0, 0, 0.04);
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(16, 42, 67, 0.05);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .role-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(16, 42, 67, 0.1) !important;
        border-color: rgba(0, 0, 0, 0.08);
    }
    .role-card:hover .fa-arrow-right {
        transform: translateX(4px);
    }
    .transition-transform {
        transition: transform 0.3s ease;
    }
</style>
