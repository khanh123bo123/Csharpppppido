@model IEnumerable<TouristGuideWeb.Models.ScanLogDto>
@{
    ViewData["Title"] = "Thống kê lượt quét QR";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3 mb-0 text-gray-800">📊 Giám sát hệ thống (Monitoring)</h1>
            <p class="text-muted">Theo dõi lượt quét mã QR thực tế từ du khách</p>
        </div>
    </div>

    <div class="card shadow mb-4 border-left-primary">
        <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
            <h6 class="m-0 font-weight-bold text-primary">Lịch sử quét mã QR (Đã lọc trùng 10 phút)</h6>
            <span class="badge bg-info">Tổng cộng: @Model.Count() lượt</span>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="scanLogsTable" width="100%" cellspacing="0">
                    <thead class="table-light">
                        <tr>
                            <th>Thời gian</th>
                            <th>Địa điểm</th>
                            <th>Ngôn ngữ</th>
                            <th>Thiết bị (ID)</th>
                            <th>Địa chỉ IP</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.OrderByDescending(l => l.ScannedAt))
                        {
                            <tr>
                                <td>@log.ScannedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>
                                    <span class="fw-bold">@log.LocationName</span>
                                </td>
                                <td>
                                    @{
                                        var langName = log.LanguageCode switch {
                                            "vi-VN" => "🇻🇳 Tiếng Việt",
                                            "en-US" => "🇺🇸 Tiếng Anh",
                                            "ko-KR" => "🇰🇷 Tiếng Hàn",
                                            "ja-JP" => "🇯🇵 Tiếng Nhật",
                                            "zh-CN" => "🇨🇳 Tiếng Trung",
                                            _ => log.LanguageCode
                                        };
                                    }
                                    @langName
                                </td>
                                <td><code class="small">@(string.IsNullOrEmpty(log.DeviceIdentifier) ? "N/A" : log.DeviceIdentifier.Substring(0, Math.Min(8, log.DeviceIdentifier.Length)) + "...")</code></td>
                                <td>@log.UserIp</td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="fa-solid fa-radar fa-3x mb-3 d-block"></i>
                                    Chưa có lượt quét nào được ghi nhận. Hãy thử quét mã trên App!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
